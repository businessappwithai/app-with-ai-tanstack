%% ---- Section 2: Business rule — Account validation ------------------------
%%meta name: Account Validation
%%meta kind: rules
%%rule accountValidation on Account event: beforeCreate priority: 10
flowchart TD
    S([Start: Account Create]) --> Q1{name == null?}
    Q1 -->|Yes| E1[Prevent: Name is required]
    Q1 -->|No| Q2{email == null?}
    Q2 -->|Yes| E2[Prevent: Email is required]
    Q2 -->|No| Q3{email format invalid?}
    Q3 -->|Yes| E3[Prevent: Email must be a valid email address]
    Q3 -->|No| Q4{phone == null?}
    Q4 -->|Yes| E4[Prevent: Phone is required]
    Q4 -->|No| P(Pass Validation)
    E1 --> END([End: Validated])
    E2 --> END
    E3 --> END
    E4 --> END
    P --> END

%% ---- Section 3: Business rule — Contact validation ------------------------
%%meta name: Contact Validation
%%meta kind: rules
%%rule contactValidation on Contact event: beforeCreate priority: 10
flowchart TD
    S([Start: Contact Create]) --> Q1{first_name == null?}
    Q1 -->|Yes| E1[Prevent: First name is required]
    Q1 -->|No| Q2{last_name == null?}
    Q2 -->|Yes| E2[Prevent: Last name is required]
    Q2 -->|No| Q3{email == null?}
    Q3 -->|Yes| E3[Prevent: Email is required]
    Q3 -->|No| Q4{email format invalid?}
    Q4 -->|Yes| E4[Prevent: Email must be a valid email address]
    Q4 -->|No| Q5{phone == null?}
    Q5 -->|Yes| E5[Prevent: Phone is required]
    Q5 -->|No| Q6{account_id == null?}
    Q6 -->|Yes| E6[Prevent: Account is required]
    Q6 -->|No| P(Pass Validation)
    E1 --> END([End: Validated])
    E2 --> END
    E3 --> END
    E4 --> END
    E5 --> END
    E6 --> END
    P --> END

%% ---- Section 4: Business rule — Opportunity validation --------------------
%%meta name: Opportunity Validation
%%meta kind: rules
%%rule opportunityValidation on Opportunity event: beforeCreate priority: 10
flowchart TD
    S([Start: Opportunity Create]) --> Q1{name == null?}
    Q1 -->|Yes| E1[Prevent: Name is required]
    Q1 -->|No| Q2{amount == null?}
    Q2 -->|Yes| E2[Prevent: Amount is required]
    Q2 -->|No| Q3{amount <= 0?}
    Q3 -->|Yes| E3[Prevent: Amount must be greater than zero]
    Q3 -->|No| Q4{stage == null?}
    Q4 -->|Yes| E4[Prevent: Stage is required]
    Q4 -->|No| Q5{stage not in valid enum?}
    Q5 -->|Yes| E5[Prevent: Stage must be a valid pipeline stage]
    Q5 -->|No| Q6{account_id == null?}
    Q6 -->|Yes| E6[Prevent: Account is required]
    Q6 -->|No| Q7{close_date == null?}
    Q7 -->|Yes| E7[Prevent: Close date is required]
    Q7 -->|No| P(Pass Validation)
    E1 --> END([End: Validated])
    E2 --> END
    E3 --> END
    E4 --> END
    E5 --> END
    E6 --> END
    E7 --> END
    P --> END

%% ---- Section 5: Business rule — Opportunity probability scoring -----------
%%meta name: Opportunity Probability Scoring
%%meta kind: rules
%%rule opportunityScoring on Opportunity event: beforeUpdate priority: 20
flowchart TD
    S([Start: Opportunity Updated]) --> Q1{stage == closed_won?}
    Q1 -->|Yes| W[Set Probability 100%]
    Q1 -->|No| Q2{stage == closed_lost?}
    Q2 -->|Yes| L[Set Probability 0%]
    Q2 -->|No| Q3{stage == negotiation?}
    Q3 -->|Yes| H[Set Probability 70%]
    Q3 -->|No| Q4{stage == proposal?}
    Q4 -->|Yes| M[Set Probability 50%]
    Q4 -->|No| D[Set Probability 20%]
    W --> C((Recompute Forecast))
    L --> C
    H --> C
    M --> C
    D --> C
    C --> E([End: Scored])

%% ---- Section 6: Business rule — Activity validation ----------------------
%%meta name: Activity Validation
%%meta kind: rules
%%rule activityValidation on Activity event: beforeCreate priority: 10
flowchart TD
    S([Start: Activity Create]) --> Q1{type == null?}
    Q1 -->|Yes| E1[Prevent: Type is required]
    Q1 -->|No| Q2{type not in valid enum?}
    Q2 -->|Yes| E2[Prevent: Type must be one of: call, email, meeting, task, note]
    Q2 -->|No| Q3{description == null?}
    Q3 -->|Yes| E3[Prevent: Description is required]
    Q3 -->|No| Q4{contact_id == null?}
    Q4 -->|Yes| E4[Prevent: Contact is required]
    Q4 -->|No| Q5{opportunity_id == null?}
    Q5 -->|Yes| E5[Prevent: Opportunity is required]
    Q5 -->|No| Q6{activity_date == null?}
    Q6 -->|Yes| E6[Prevent: Activity date is required]
    Q6 -->|No| P(Pass Validation)
    E1 --> END([End: Validated])
    E2 --> END
    E3 --> END
    E4 --> END
    E5 --> END
    E6 --> END
    P --> END

%% ---- Section 7: Workflow — Opportunity lifecycle (state machine) ----------
%%meta name: Opportunity Lifecycle
%%meta kind: workflow
%%workflow OpportunityLifecycle entity: Opportunity kind: state
stateDiagram-v2
    [*]           --> prospecting
    prospecting   --> qualification : qualify
    qualification --> proposal      : send_proposal
    proposal      --> negotiation   : negotiate
    negotiation   --> closed_won    : close_won
    negotiation   --> closed_lost   : close_lost
    closed_won    --> [*]
    closed_lost   --> [*]

    %%guard role:sales|manager on Opportunity.update
    %%guard role:manager on Opportunity.close_won
    %%trigger cron:0 9 * * 1 -> nudgeStaleOpportunities on Opportunity

