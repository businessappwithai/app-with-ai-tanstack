{
  "name": "@erdwithai/generator",
  "version": "5.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "erdwithai": "./dist/cli/generate.js",
    "erdwithai-generate": "./dist/cli/generate.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "@erdwithai/core": "workspace:*",
    "handlebars": "^4.7.8",
    "commander": "^11.1.0",
    "prettier": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.3",
    "@vitest/coverage-v8": "^1.1.3"
  },
  "scripts": {
    "build": "bun build src/index.ts src/cli/generate.ts --outdir dist --target node --format esm --external @erdwithai/core --external handlebars --external commander --external prettier",
    "generate": "node dist/cli/generate.js generate",
    "dev": "bun run build && bun run generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
