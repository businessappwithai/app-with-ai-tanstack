/**
 * Business Data Seed
 * Sample records for each business entity for E2E testing
 *
 * Generated: {{now}}
 */

import { Kysely, sql } from 'kysely';
import { v4 as uuidv4 } from 'uuid';

export async function seed(db: Kysely<any>): Promise<void> {
  const now = new Date();

  // Disable FK constraint checking during bulk seed to allow any insertion order
  await sql`SET session_replication_role = replica`.execute(db);

  {{#each entities}}
  // {{displayName}} ({{tableName}})
  await db.deleteFrom('{{tableName}}').execute();

  const {{camelCase name}}Records = [
    {{#each (range 1 4)}}
    {
      id: uuidv4(),
      {{#each ../attributes}}
      {{#unless (eq name ../../primaryKey)}}
      {{#unless (eq name 'created_at')}}
      {{#unless (eq name 'updated_at')}}
      {{#unless (eq name 'deleted_at')}}
      {{#unless (eq name 'version')}}
      {{#switch (typeToReferenceId type)}}
        {{#case 10}}{{name}}: {{#if (endsWith name '_id')}}uuidv4(){{else}}'{{#if (eq name "email")}}{{camelCase ../../name}}{{@../index}}@school.edu{{else}}{{seedValue name @../index}}{{/if}}'{{/if}},{{/case}}
        {{#case 30}}{{name}}: '{{camelCase ../../name}}{{@../index}}@school.edu',{{/case}}
        {{#case 31}}{{name}}: '555-{{@../index}}101',{{/case}}
        {{#case 11}}{{name}}: {{#if (endsWith name '_id')}}uuidv4(){{else}}{{@../index}}{{/if}},{{/case}}
        {{#case 12}}{{name}}: {{@../index}}.50,{{/case}}
        {{#case 15}}{{name}}: new Date('200{{@../index}}-0{{@../index}}-15'),{{/case}}
        {{#case 16}}{{name}}: new Date(Date.now() + {{@../index}} * 3600000),{{/case}}
        {{#case 20}}{{name}}: {{#if (eq @../index 2)}}false{{else}}true{{/if}},{{/case}}
        {{#case 13}}{{name}}: uuidv4(),{{/case}}
        {{#case 14}}{{name}}: 'Sample {{name}} for record {{@../index}}',{{/case}}
        {{#default}}{{name}}: '{{seedValue name @../index}}',{{/default}}
      {{/switch}}
      {{/unless}}
      {{/unless}}
      {{/unless}}
      {{/unless}}
      {{/unless}}
      {{/each}}
      version: 1,
      created_at: now,
      updated_at: now,
      deleted_at: null,
    },
    {{/each}}
  ];

  await db.insertInto('{{tableName}}').values({{camelCase name}}Records).execute();

  {{/each}}

  // Re-enable FK constraint checking
  await sql`SET session_replication_role = DEFAULT`.execute(db);

  console.log('✓ Business sample data seeded');
}
