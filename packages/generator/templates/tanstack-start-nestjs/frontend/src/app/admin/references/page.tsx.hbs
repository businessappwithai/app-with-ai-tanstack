/**
 * Reference Types - Field Type and Validation Manager
 *
 * Professional tool for viewing and managing field reference types,
 * validation rules, and lookup definitions from the Application Dictionary.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

'use client';

import { useState } from 'react';
import Link from 'next/link';
import { useQuery } from '@tanstack/react-query';
import { apiClient, PaginatedResponse } from '@/lib/api-client';
import {
  Hash,
  ArrowLeft,
  Search,
  RefreshCw,
  FileText,
  List,
  Check,
  X,
  Database,
} from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

interface Reference {
  sys_reference_id: string;
  name: string;
  description?: string;
  validation?: string;
  is_active?: boolean;
}

// Reference type icons based on name patterns
function getReferenceIcon(name: string) {
  const lower = name.toLowerCase();
  if (lower.includes('string')) return 'Aa';
  if (lower.includes('int') || lower.includes('number')) return '123';
  if (lower.includes('date')) return '📅';
  if (lower.includes('bool') || lower.includes('yes')) return '✓';
  if (lower.includes('table') || lower.includes('ref')) return '🔗';
  if (lower.includes('list')) return '☰';
  return '•';
}

// Get reference type category
function getReferenceCategory(name: string): 'primitive' | 'table' | 'list' | 'other' {
  const lower = name.toLowerCase();
  if (lower.includes('table') || lower.includes('ref') || lower.includes('direct')) return 'table';
  if (lower.includes('list')) return 'list';
  if (lower.includes('string') || lower.includes('int') || lower.includes('date') || lower.includes('bool')) {
    return 'primitive';
  }
  return 'other';
}

// Get category styling
function getCategoryStyle(category: string) {
  switch (category) {
    case 'primitive':
      return 'bg-blue-100 text-blue-700 border-blue-200';
    case 'table':
      return 'bg-green-100 text-green-700 border-green-200';
    case 'list':
      return 'bg-purple-100 text-purple-700 border-purple-200';
    default:
      return 'bg-muted text-foreground border-border';
  }
}

export default function ReferenceTypesPage() {
  const [searchQuery, setSearchQuery] = useState('');

  // Fetch references
  const { data: referencesResponse, isLoading: referencesLoading, refetch: refetchReferences } = useQuery({
    queryKey: ['admin', 'references-list'],
    queryFn: () => apiClient.get<PaginatedResponse<Reference>>('/api/sys/references', { limit: 200 }),
  });

  const references = referencesResponse?.data || [];

  // Group references by category
  const groupedReferences = {
    primitive: references.filter(r => getReferenceCategory(r.name) === 'primitive'),
    table: references.filter(r => getReferenceCategory(r.name) === 'table'),
    list: references.filter(r => getReferenceCategory(r.name) === 'list'),
    other: references.filter(r => getReferenceCategory(r.name) === 'other'),
  };

  // Filter references based on search
  const filteredReferences = references.filter((ref) => {
    return searchQuery === '' ||
      ref.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      (ref.description && ref.description.toLowerCase().includes(searchQuery.toLowerCase()));
  });

  const categories: Array<{ key: keyof typeof groupedReferences; label: string; description: string; icon: any }> = [
    { key: 'primitive', label: 'Primitive Types', description: 'Basic data types like String, Integer, Date', icon: FileText },
    { key: 'table', label: 'Table References', description: 'Foreign key references to other tables', icon: Database },
    { key: 'list', label: 'List References', description: 'Predefined value lists and dropdowns', icon: List },
    { key: 'other', label: 'Other References', description: 'Custom and special reference types', icon: Hash },
  ];

  return (
    <div className="min-h-screen bg-background">
      {/* Swiss Clean Header */}
      <header className="border-b-4 border-border bg-background">
        <div className="max-w-7xl mx-auto px-8 py-12">
          <div className="flex items-start justify-between">
            <div className="flex-1">
              <div className="flex items-center gap-3 mb-4">
                <Hash className="h-8 w-8" style={{ color: '#059669' }} />
                <h1 className="text-6xl font-bold tracking-tight text-foreground font-display">
                  Reference Types
                </h1>
              </div>
              <p className="text-xl text-muted-foreground font-light max-w-2xl leading-relaxed">
                Manage field types, validation rules, and lookup definitions
              </p>
            </div>
            <Button
              variant="outline"
              size="default"
              onClick={() => refetchReferences()}
              disabled={referencesLoading}
              className="border-2 border-border hover:bg-black hover:text-white transition-colors rounded-none"
            >
              <RefreshCw className={`h-4 w-4 mr-2 ${referencesLoading ? 'animate-spin' : ''}`} />
              Refresh
            </Button>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-8 py-12">
        {/* Back to Admin */}
        <div className="mb-8">
          <Link href="/admin" className="inline-flex items-center text-sm hover:underline">
            <ArrowLeft className="h-4 w-4 mr-2" />
            Back to Admin Dashboard
          </Link>
        </div>

        {/* Statistics Cards */}
        <div className="mb-12 grid grid-cols-4 gap-0 border-2 border-border">
          <div className="border-r border-border p-6">
            <div className="flex items-center gap-2 mb-2">
              <FileText className="h-5 w-5 text-blue-600" />
              <h3 className="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Primitive</h3>
            </div>
            <p className="text-4xl font-bold">{groupedReferences.primitive.length}</p>
          </div>
          <div className="border-r border-border p-6">
            <div className="flex items-center gap-2 mb-2">
              <Database className="h-5 w-5 text-green-600" />
              <h3 className="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Table Refs</h3>
            </div>
            <p className="text-4xl font-bold">{groupedReferences.table.length}</p>
          </div>
          <div className="border-r border-border p-6">
            <div className="flex items-center gap-2 mb-2">
              <List className="h-5 w-5 text-purple-600" />
              <h3 className="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Lists</h3>
            </div>
            <p className="text-4xl font-bold">{groupedReferences.list.length}</p>
          </div>
          <div className="p-6">
            <div className="flex items-center gap-2 mb-2">
              <Hash className="h-5 w-5 text-muted-foreground" />
              <h3 className="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Other</h3>
            </div>
            <p className="text-4xl font-bold">{groupedReferences.other.length}</p>
          </div>
        </div>

        {/* Search */}
        <div className="mb-8">
          <div className="relative">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" />
            <Input
              type="text"
              placeholder="Search reference types by name or description..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="pl-10 border-2 border-border rounded-none focus:ring-0 focus:border-border"
            />
          </div>
          <div className="mt-2 text-sm text-muted-foreground">
            <span className="font-bold">{filteredReferences.length}</span> of {references.length} reference types
            {searchQuery && ` matching "${searchQuery}"`}
          </div>
        </div>

        {/* Loading State */}
        {referencesLoading ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">
            Loading reference types...
          </div>
        ) : (
          <>
            {/* Display by Category */}
            {searchQuery === '' ? (
              // Grouped view when no search
              categories.map((category) => {
                const categoryRefs = groupedReferences[category.key];
                if (categoryRefs.length === 0) return null;

                return (
                  <div key={category.key} className="mb-12">
                    <div className="flex items-center gap-3 mb-6">
                      <category.icon className={`h-6 w-6 ${category.key === 'primitive' ? 'text-blue-600' : category.key === 'table' ? 'text-green-600' : category.key === 'list' ? 'text-purple-600' : 'text-muted-foreground'}`} />
                      <div>
                        <h2 className="text-2xl font-bold font-display">{category.label}</h2>
                        <p className="text-sm text-muted-foreground">{category.description}</p>
                      </div>
                      <Badge className="ml-auto" variant="outline">{categoryRefs.length} types</Badge>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                      {categoryRefs.map((ref) => (
                        <Card key={ref.sys_reference_id} className="border-2 border-border hover:border-gray-400 transition-colors">
                          <CardHeader className="pb-3">
                            <div className="flex items-start justify-between">
                              <div className="flex items-center gap-2">
                                <span className="text-2xl">{getReferenceIcon(ref.name)}</span>
                                <CardTitle className="text-lg">{ref.name}</CardTitle>
                              </div>
                              {ref.is_active !== undefined && (
                                <Badge variant={ref.is_active ? 'default' : 'secondary'}>
                                  {ref.is_active ? 'Active' : 'Inactive'}
                                </Badge>
                              )}
                            </div>
                            {ref.description && (
                              <CardDescription className="text-sm mt-2">
                                {ref.description}
                              </CardDescription>
                            )}
                          </CardHeader>
                          <CardContent>
                            {ref.validation && (
                              <div className="text-xs text-muted-foreground">
                                <span className="font-semibold">Validation:</span> {ref.validation}
                              </div>
                            )}
                          </CardContent>
                        </Card>
                      ))}
                    </div>
                  </div>
                );
              })
            ) : (
              // Flat view when searching
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {filteredReferences.map((ref) => {
                  const category = getReferenceCategory(ref.name);
                  return (
                    <Card key={ref.sys_reference_id} className="border-2 border-border hover:border-gray-400 transition-colors">
                      <CardHeader className="pb-3">
                        <div className="flex items-start justify-between">
                          <div className="flex items-center gap-2">
                            <span className="text-2xl">{getReferenceIcon(ref.name)}</span>
                            <CardTitle className="text-lg">{ref.name}</CardTitle>
                          </div>
                          <Badge className={getCategoryStyle(category)}>
                            {category}
                          </Badge>
                        </div>
                        {ref.description && (
                          <CardDescription className="text-sm mt-2">
                            {ref.description}
                          </CardDescription>
                        )}
                      </CardHeader>
                      <CardContent>
                        <div className="flex items-center gap-4 text-xs text-muted-foreground">
                          {ref.is_active !== undefined && (
                            <div className="flex items-center gap-1">
                              {ref.is_active ? (
                                <Check className="h-3 w-3 text-green-600" />
                              ) : (
                                <X className="h-3 w-3 text-red-600" />
                              )}
                              <span>{ref.is_active ? 'Active' : 'Inactive'}</span>
                            </div>
                          )}
                          {ref.validation && (
                            <div>
                              <span className="font-semibold">Validation:</span> {ref.validation}
                            </div>
                          )}
                        </div>
                      </CardContent>
                    </Card>
                  );
                })}
              </div>
            )}
          </>
        )}
      </main>
    </div>
  );
}
