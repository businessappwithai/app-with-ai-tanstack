/**
 * Swiss Clean Design System
 *
 * Editorial elegance with Newsreader serif headlines
 * Technical precision with JetBrains Mono metrics
 * Clean body text with Inter
 * Refined borders instead of shadows
 *
 * Color Palette:
 * - Primary: Teal (#0D6E6E)
 * - Destructive: Orange (#E07B54)
 * - Backgrounds: Light (#FAFAFA, #FFFFFF)
 * - Borders: Refined (#E5E5E5)
 * - Text: Dark (#1A1A1A, #666666, #888888)
 *
 * Generated: {{now}}
 * Project: {{projectName}}
 */

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* Swiss Clean Color Palette */
    --background: 250 10% 98%; /* #FAFAFA */
    --foreground: 0 0% 10%; /* #1A1A1A */

    --card: 0 0% 100%; /* #FFFFFF */
    --card-foreground: 0 0% 10%; /* #1A1A1A */

    --popover: 0 0% 100%; /* #FFFFFF */
    --popover-foreground: 0 0% 10%; /* #1A1A1A */

    --primary: 182 78% 27%; /* #0D6E6E - Teal */
    --primary-foreground: 0 0% 100%; /* #FFFFFF */

    --secondary: 210 10% 96%; /* #F5F5F5 */
    --secondary-foreground: 0 0% 10%; /* #1A1A1A */

    --muted: 210 10% 96%; /* #F5F5F5 */
    --muted-foreground: 0 0% 53%; /* #888888 */

    --accent: 182 78% 27%; /* #0D6E6E - Teal */
    --accent-foreground: 0 0% 100%; /* #FFFFFF */

    --destructive: 17 76% 60%; /* #E07B54 - Orange */
    --destructive-foreground: 0 0% 100%; /* #FFFFFF */

    --border: 210 10% 90%; /* #E5E5E5 */
    --input: 210 10% 90%; /* #E5E5E5 */
    --ring: 182 78% 27%; /* #0D6E6E - Teal */

    --radius: 0.75rem; /* 12px - rounded-xl */

    /* Swiss Clean Special Colors */
    --swiss-bg-light: 250 10% 98%; /* #FAFAFA */
    --swiss-bg-white: 0 0% 100%; /* #FFFFFF */
    --swiss-border: 210 10% 90%; /* #E5E5E5 */
    --swiss-text-dark: 0 0% 10%; /* #1A1A1A */
    --swiss-text-medium: 0 0% 40%; /* #666666 */
    --swiss-text-light: 0 0% 53%; /* #888888 */
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground;
    font-feature-settings: "rlig" 1, "calt" 1;
  }

  /* Swiss Clean Typography */
  .font-display {
    font-family: 'Newsreader', Georgia, serif;
    font-optical-sizing: auto;
  }

  .font-mono-display {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-feature-settings: "tnum" 1, "zero" 1;
    letter-spacing: -0.02em;
  }
}

@layer utilities {
  /* Swiss Clean Container */
  .container-swiss {
    @apply mx-auto w-full max-w-[1440px] px-6 lg:px-8;
  }

  /* Swiss Clean Card */
  .swiss-card {
    @apply rounded-xl border border-border bg-card;
  }

  /* Swiss Clean Badge */
  .badge-swiss {
    @apply inline-flex items-center rounded-lg px-3 py-1.5 text-xs font-semibold font-mono-display uppercase;
  }

  .badge-teal {
    @apply badge-swiss bg-[#F8F8F8] text-[#0D6E6E];
  }

  .badge-orange {
    @apply badge-swiss bg-[#FEF3F2] text-[#E07B54];
  }

  .badge-gray {
    @apply badge-swiss bg-[#FAFAFA] text-[#888888];
  }

  /* Swiss Clean Section Header */
  .section-header {
    @apply font-mono-display text-[11px] font-semibold tracking-wider uppercase text-muted-foreground;
  }

  /* Swiss Clean Metric Card */
  .metric-card {
    @apply swiss-card p-5 flex flex-col gap-3 h-[146px];
  }

  .metric-label {
    @apply text-xs font-medium text-muted-foreground;
  }

  .metric-value {
    @apply font-mono-display text-3xl font-bold leading-tight text-foreground;
  }

  .metric-description {
    @apply font-display text-sm italic text-muted-foreground;
  }

  /* Swiss Clean Input */
  .input-swiss {
    @apply h-12 w-full rounded-lg border border-border bg-transparent px-4 py-3 text-sm ring-offset-background transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50;
  }

  /* Swiss Clean Button */
  .btn-swiss {
    @apply inline-flex items-center justify-center rounded-lg text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50;
  }

  .btn-swiss-primary {
    @apply btn-swiss bg-primary text-primary-foreground hover:bg-primary/90;
  }

  .btn-swiss-secondary {
    @apply btn-swiss bg-secondary text-secondary-foreground hover:bg-secondary/80;
  }

  .btn-swiss-outline {
    @apply btn-swiss border border-border bg-background hover:bg-accent hover:text-accent-foreground;
  }

  .btn-swiss-ghost {
    @apply btn-swiss hover:bg-accent hover:text-accent-foreground;
  }

  .btn-swiss-destructive {
    @apply btn-swiss bg-destructive text-destructive-foreground hover:bg-destructive/90;
  }
}

/* Swiss Clean Animations */
@keyframes fade-in {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fade-in 0.3s ease-out;
}

/* Swiss Clean Scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  @apply bg-transparent;
}

::-webkit-scrollbar-thumb {
  @apply bg-border rounded-lg;
}

::-webkit-scrollbar-thumb:hover {
  @apply bg-muted-foreground/30;
}
