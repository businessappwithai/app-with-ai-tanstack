import { createFileRoute, Link } from '@tanstack/react-router';
import { useState } from 'react';
import { useQuery } from '@tanstack/react-query';
import { apiClient, PaginatedResponse } from '@/lib/api-client';
import {
  Database,
  Table2,
  ArrowLeft,
  Search,
  RefreshCw,
} from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Badge } from '@/components/ui/badge';

export const Route = createFileRoute('/admin/tables')({
  component: TableBrowserPage,
});

interface SysTable {
  sys_table_id: string;
  name: string;
  table_name: string;
  description?: string;
  is_active?: boolean;
}

function TableBrowserPage() {
  const [searchQuery, setSearchQuery] = useState('');
  const [filterPrefix, setFilterPrefix] = useState<string>('bus_');

  const { data: tablesResponse, isLoading: tablesLoading, refetch: refetchTables } = useQuery({
    queryKey: ['admin', 'tables-browser'],
    queryFn: () => apiClient.get<PaginatedResponse<SysTable>>('/api/sys/tables/all', { limit: 200 }),
  });

  const tables = tablesResponse?.data || [];

  const filteredTables = tables.filter((table) => {
    const matchesSearch = searchQuery === '' ||
      table.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      table.table_name.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesPrefix = filterPrefix === '' || table.table_name.startsWith(filterPrefix);
    return matchesSearch && matchesPrefix;
  });

  return (
    <div className="min-h-screen bg-background">
      <header className="border-b-4 border-border bg-background">
        <div className="max-w-7xl mx-auto px-8 py-12">
          <div className="flex items-start justify-between">
            <div className="flex-1">
              <div className="flex items-center gap-3 mb-4">
                <Database className="h-8 w-8 text-blue-600" />
                <h1 className="text-6xl font-bold tracking-tight text-foreground font-display">
                  Table Browser
                </h1>
              </div>
              <p className="text-xl text-muted-foreground font-light max-w-2xl leading-relaxed">
                View database structure, column definitions, and table relationships
              </p>
            </div>
            <Button
              variant="outline"
              size="default"
              onClick={() => refetchTables()}
              disabled={tablesLoading}
              className="border-2 border-border hover:bg-black hover:text-white transition-colors rounded-none"
            >
              <RefreshCw className={`h-4 w-4 mr-2 ${tablesLoading ? 'animate-spin' : ''}`} />
              Refresh
            </Button>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-8 py-12">
        <div className="mb-8">
          <Link to="/admin" className="inline-flex items-center text-sm hover:underline">
            <ArrowLeft className="h-4 w-4 mr-2" />
            Back to Admin Dashboard
          </Link>
        </div>

        <div className="mb-8 flex gap-4">
          <div className="flex-1 relative">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" />
            <Input
              type="text"
              placeholder="Search tables by name or table name..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="pl-10 border-2 border-border rounded-none focus:ring-0 focus:border-border"
            />
          </div>
          <div className="flex gap-2">
            <Button
              variant={filterPrefix === 'bus_' ? 'default' : 'outline'}
              onClick={() => setFilterPrefix('bus_')}
              className={`rounded-none ${filterPrefix === 'bus_' ? 'bg-black text-white hover:bg-gray-800' : 'border-2 border-border hover:bg-black hover:text-white'}`}
            >
              Business
            </Button>
            <Button
              variant={filterPrefix === 'sys_' ? 'default' : 'outline'}
              onClick={() => setFilterPrefix('sys_')}
              className={`rounded-none ${filterPrefix === 'sys_' ? 'bg-black text-white hover:bg-gray-800' : 'border-2 border-border hover:bg-black hover:text-white'}`}
            >
              System
            </Button>
            <Button
              variant={filterPrefix === '' ? 'default' : 'outline'}
              onClick={() => setFilterPrefix('')}
              className={`rounded-none ${filterPrefix === '' ? 'bg-black text-white hover:bg-gray-800' : 'border-2 border-border hover:bg-black hover:text-white'}`}
            >
              All
            </Button>
          </div>
        </div>

        <div className="mb-6 text-sm">
          <span className="font-bold">{filteredTables.length}</span> of {tables.length} tables
          {searchQuery && ` matching "${searchQuery}"`}
          {filterPrefix && ` starting with ${filterPrefix}`}
        </div>

        {tablesLoading ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">Loading tables...</div>
        ) : filteredTables.length === 0 ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">
            {searchQuery || filterPrefix ? 'No tables match your search criteria.' : 'No tables found.'}
          </div>
        ) : (
          <div className="border-2 border-border">
            {filteredTables.map((table, index) => (
              <a
                key={table.sys_table_id || table.table_name}
                href={`/admin/tables/${table.table_name}`}
                className={`block px-6 py-4 flex items-center gap-4 hover:bg-blue-50 transition-colors text-left ${index > 0 ? 'border-t-2 border-border' : ''}`}
              >
                <Table2 className="h-5 w-5 flex-shrink-0 text-blue-600" />
                <div className="flex-1">
                  <div className="flex items-center gap-3 mb-1">
                    <h3 className="text-lg font-bold">{table.name}</h3>
                    <code className="text-xs px-2 py-1 bg-gray-100 text-gray-700 font-mono">{table.table_name}</code>
                    {table.is_active !== undefined && (
                      <Badge variant={table.is_active ? 'default' : 'secondary'}>
                        {table.is_active ? 'Active' : 'Inactive'}
                      </Badge>
                    )}
                  </div>
                  {table.description && <p className="text-sm text-muted-foreground">{table.description}</p>}
                </div>
                <div className="text-sm text-blue-600 font-medium group-hover:underline">View & Edit →</div>
              </a>
            ))}
          </div>
        )}
      </main>
    </div>
  );
}
