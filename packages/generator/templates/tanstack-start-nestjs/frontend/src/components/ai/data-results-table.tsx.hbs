{{#if config.aiNlAddon}}
/**
 * Data Results Table Component
 *
 * Displays AI query results in a compact table format.
 * Used by the AI Chat component for tabular data display.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

'use client';

import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '@/components/ui/table';

// ============================================================================
// Types
// ============================================================================

interface DataResultsTableProps {
  data: Record<string, unknown>[];
  entity: string;
  maxRows?: number;
}

// ============================================================================
// Component
// ============================================================================

export function DataResultsTable({
  data,
  entity,
  maxRows = 5,
}: DataResultsTableProps) {
  if (!data || data.length === 0) {
    return (
      <div className="text-sm text-muted-foreground py-2">
        No results found
      </div>
    );
  }

  // Get column headers from first row
  const columns = Object.keys(data[0]).filter(
    (col) => !col.endsWith('_id') && col !== 'version' && col !== 'created_at' && col !== 'updated_at'
  );

  // Limit displayed rows
  const displayedData = data.slice(0, maxRows);
  const hasMore = data.length > maxRows;

  return (
    <div className="rounded border overflow-hidden">
      <Table>
        <TableHeader>
          <TableRow className="bg-muted/50">
            {columns.map((column) => (
              <TableHead key={column} className="text-xs font-medium py-1 px-2">
                {formatColumnName(column)}
              </TableHead>
            ))}
          </TableRow>
        </TableHeader>
        <TableBody>
          {displayedData.map((row, rowIndex) => (
            <TableRow key={rowIndex} className="hover:bg-muted/30">
              {columns.map((column) => (
                <TableCell key={column} className="text-xs py-1 px-2">
                  {formatCellValue(row[column])}
                </TableCell>
              ))}
            </TableRow>
          ))}
        </TableBody>
      </Table>
      {hasMore && (
        <div className="text-xs text-muted-foreground text-center py-1 bg-muted/30">
          Showing {maxRows} of {data.length} results
        </div>
      )}
    </div>
  );
}

// ============================================================================
// Helpers
// ============================================================================

function formatColumnName(column: string): string {
  return column
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

function formatCellValue(value: unknown): string {
  if (value === null || value === undefined) {
    return '-';
  }

  if (typeof value === 'boolean') {
    return value ? 'Yes' : 'No';
  }

  if (value instanceof Date) {
    return value.toLocaleDateString();
  }

  if (typeof value === 'number') {
    return value.toLocaleString();
  }

  const strValue = String(value);
  // Truncate long values
  return strValue.length > 30 ? strValue.slice(0, 30) + '...' : strValue;
}

export default DataResultsTable;
{{else}}
// AI NL Add-on is not enabled for this project
export {}
{{/if}}
