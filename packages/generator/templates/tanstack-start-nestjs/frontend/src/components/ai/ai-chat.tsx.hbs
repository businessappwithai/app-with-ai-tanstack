{{#if config.aiNlAddon}}
/**
 * AI Chat Component (CopilotKit Integration)
 *
 * Provides natural language data access using:
 * - CopilotKit for chat interface
 * - Mastra.ai for query processing
 * - Knex.js Query Builder for data access
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

'use client';

import { useState } from 'react';
import {
  CopilotKit,
  CopilotSidebar,
  CopilotChat,
  useCopilotAction,
  useCopilotReadable,
} from '@copilotkit/react-core';
import { CopilotTextarea } from '@copilotkit/react-textarea';
import { useQuery } from '@tanstack/react-query';
import { apiClient } from '@/lib/api-client';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { MessageSquare, X, Loader2 } from 'lucide-react';
import { cn } from '@/lib/utils';
import { DataResultsTable } from './data-results-table';
import { DataResultsChart } from './data-results-chart';

// ============================================================================
// Types
// ============================================================================

interface AIQueryResult {
  success: boolean;
  data: Record<string, unknown>[];
  count: number;
  entity: string;
  query: string;
  displayHint: 'table' | 'chart' | 'number';
  executionTimeMs: number;
  summary: string;
}

interface AIMessage {
  role: 'user' | 'assistant';
  content: string;
  result?: AIQueryResult;
  timestamp: Date;
}

// ============================================================================
// AI Chat Provider
// ============================================================================

interface AIChatProviderProps {
  children: React.ReactNode;
}

export function AIChatProvider({ children }: AIChatProviderProps) {
  return (
    <CopilotKit
      runtimeUrl="/api/copilotkit"
      publicApiKey={process.env.NEXT_PUBLIC_COPILOT_API_KEY}
    >
      {children}
    </CopilotKit>
  );
}

// ============================================================================
// AI Chat Panel
// ============================================================================

interface AIChatPanelProps {
  className?: string;
}

export function AIChatPanel({ className }: AIChatPanelProps) {
  const [isOpen, setIsOpen] = useState(false);
  const [messages, setMessages] = useState<AIMessage[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const [currentResult, setCurrentResult] = useState<AIQueryResult | null>(null);

  // Make current page context readable to CopilotKit
  useCopilotReadable({
    description: 'Current application context',
    value: {
      availableEntities: [
        {{#each entities}}
        '{{name}}',
        {{/each}}
      ],
      currentPage: typeof window !== 'undefined' ? window.location.pathname : '/',
    },
  });

  // Register the data query action
  useCopilotAction({
    name: 'queryData',
    description: 'Query data from the database using natural language',
    parameters: [
      {
        name: 'query',
        type: 'string',
        description: 'The natural language query',
        required: true,
      },
    ],
    handler: async ({ query }) => {
      return await executeQuery(query);
    },
  });

  const executeQuery = async (query: string) => {
    setIsLoading(true);
    try {
      const response = await apiClient.post<AIQueryResult>('/api/ai/query', {
        query,
      });

      const result = response.data;

      setMessages((prev) => [
        ...prev,
        {
          role: 'user',
          content: query,
          timestamp: new Date(),
        },
        {
          role: 'assistant',
          content: result.summary,
          result,
          timestamp: new Date(),
        },
      ]);

      setCurrentResult(result);
      return result;
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Query failed';
      setMessages((prev) => [
        ...prev,
        {
          role: 'user',
          content: query,
          timestamp: new Date(),
        },
        {
          role: 'assistant',
          content: `Error: ${errorMessage}`,
          timestamp: new Date(),
        },
      ]);
      throw error;
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <>
      {/* Toggle Button */}
      <Button
        onClick={() => setIsOpen(!isOpen)}
        className={cn(
          'fixed bottom-4 right-4 h-14 w-14 rounded-full shadow-lg',
          'bg-primary hover:bg-primary/90',
          className
        )}
        size="icon"
      >
        {isOpen ? (
          <X className="h-6 w-6" />
        ) : (
          <MessageSquare className="h-6 w-6" />
        )}
      </Button>

      {/* Chat Panel */}
      {isOpen && (
        <Card className="fixed bottom-20 right-4 w-96 max-h-[600px] shadow-xl z-50">
          <CardHeader className="pb-2">
            <CardTitle className="text-lg flex items-center gap-2">
              <MessageSquare className="h-5 w-5" />
              AI Data Assistant
            </CardTitle>
          </CardHeader>
          <CardContent className="flex flex-col h-[500px]">
            {/* Messages */}
            <div className="flex-1 overflow-y-auto space-y-4 mb-4">
              {messages.length === 0 && (
                <div className="text-muted-foreground text-center py-8">
                  <p>Ask me anything about your data!</p>
                  <p className="text-sm mt-2">Examples:</p>
                  <ul className="text-sm mt-1 space-y-1">
                    <li>"Show me all customers from New York"</li>
                    <li>"How many orders were placed this month?"</li>
                    <li>"What's the average order value?"</li>
                  </ul>
                </div>
              )}

              {messages.map((message, index) => (
                <div
                  key={index}
                  className={cn(
                    'flex',
                    message.role === 'user' ? 'justify-end' : 'justify-start'
                  )}
                >
                  <div
                    className={cn(
                      'max-w-[80%] rounded-lg px-4 py-2',
                      message.role === 'user'
                        ? 'bg-primary text-primary-foreground'
                        : 'bg-muted'
                    )}
                  >
                    <p className="text-sm">{message.content}</p>
                    {message.result && (
                      <ResultDisplay result={message.result} />
                    )}
                  </div>
                </div>
              ))}

              {isLoading && (
                <div className="flex justify-start">
                  <div className="bg-muted rounded-lg px-4 py-2">
                    <Loader2 className="h-4 w-4 animate-spin" />
                  </div>
                </div>
              )}
            </div>

            {/* Input */}
            <div className="border-t pt-4">
              <CopilotTextarea
                placeholder="Ask about your data..."
                className="min-h-[60px] resize-none"
                autosuggestionsConfig={{
                  textareaPurpose: 'Query business data using natural language',
                  chatApiConfigs: {},
                }}
                onKeyDown={(e) => {
                  if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    const value = (e.target as HTMLTextAreaElement).value.trim();
                    if (value) {
                      executeQuery(value);
                      (e.target as HTMLTextAreaElement).value = '';
                    }
                  }
                }}
              />
            </div>
          </CardContent>
        </Card>
      )}
    </>
  );
}

// ============================================================================
// Result Display Component
// ============================================================================

interface ResultDisplayProps {
  result: AIQueryResult;
}

function ResultDisplay({ result }: ResultDisplayProps) {
  if (result.displayHint === 'number') {
    return (
      <div className="mt-2 text-2xl font-bold">
        {result.count.toLocaleString()}
      </div>
    );
  }

  if (result.displayHint === 'chart') {
    return (
      <div className="mt-2">
        <DataResultsChart data={result.data} />
      </div>
    );
  }

  // Default: table
  return (
    <div className="mt-2 max-h-48 overflow-auto">
      <DataResultsTable data={result.data} entity={result.entity} />
    </div>
  );
}

// ============================================================================
// Sidebar Chat (Alternative Layout)
// ============================================================================

export function AISidebarChat() {
  return (
    <CopilotSidebar
      defaultOpen={false}
      instructions="You are a helpful data assistant. Help users query and understand their business data."
      labels={{
        title: 'AI Data Assistant',
        initial: 'Ask me anything about your data!',
      }}
    >
      <CopilotChat />
    </CopilotSidebar>
  );
}

export default AIChatPanel;
{{else}}
// AI NL Add-on is not enabled for this project
export {}
{{/if}}
