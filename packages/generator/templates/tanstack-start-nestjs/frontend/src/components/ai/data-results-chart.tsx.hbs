{{#if config.aiNlAddon}}
/**
 * Data Results Chart Component
 *
 * Displays AI query results in a chart format.
 * Used for aggregation queries (count, sum, avg, etc.)
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

'use client';

import { useMemo } from 'react';

// ============================================================================
// Types
// ============================================================================

interface DataResultsChartProps {
  data: Record<string, unknown>[];
  chartType?: 'bar' | 'line' | 'pie';
}

// ============================================================================
// Component
// ============================================================================

export function DataResultsChart({
  data,
  chartType = 'bar',
}: DataResultsChartProps) {
  // Auto-detect chart data from results
  const chartData = useMemo(() => {
    if (!data || data.length === 0) return null;

    // Find numeric and label columns
    const columns = Object.keys(data[0]);
    const numericCol = columns.find((col) =>
      typeof data[0][col] === 'number' && !col.endsWith('_id')
    );
    const labelCol = columns.find((col) =>
      typeof data[0][col] === 'string' && !col.endsWith('_id')
    );

    if (!numericCol) return null;

    return {
      labels: data.map((row) => String(row[labelCol || columns[0]] || 'Unknown')),
      values: data.map((row) => Number(row[numericCol]) || 0),
      labelColumn: labelCol || columns[0],
      valueColumn: numericCol,
    };
  }, [data]);

  if (!chartData) {
    return (
      <div className="text-sm text-muted-foreground py-2">
        Cannot display chart for this data
      </div>
    );
  }

  // Simple bar chart using CSS
  const maxValue = Math.max(...chartData.values);

  return (
    <div className="space-y-2">
      <div className="text-xs text-muted-foreground">
        {formatColumnName(chartData.valueColumn)} by {formatColumnName(chartData.labelColumn)}
      </div>
      <div className="space-y-1">
        {chartData.labels.slice(0, 8).map((label, index) => {
          const value = chartData.values[index];
          const percentage = maxValue > 0 ? (value / maxValue) * 100 : 0;

          return (
            <div key={index} className="flex items-center gap-2 text-xs">
              <div className="w-20 truncate text-muted-foreground" title={label}>
                {label}
              </div>
              <div className="flex-1 h-4 bg-muted rounded overflow-hidden">
                <div
                  className="h-full bg-primary transition-all duration-300"
                  style={{ width: `${percentage}%` }}
                />
              </div>
              <div className="w-12 text-right font-medium">
                {value.toLocaleString()}
              </div>
            </div>
          );
        })}
      </div>
      {chartData.labels.length > 8 && (
        <div className="text-xs text-muted-foreground text-center">
          Showing top 8 of {chartData.labels.length} results
        </div>
      )}
    </div>
  );
}

// ============================================================================
// Helpers
// ============================================================================

function formatColumnName(column: string): string {
  return column
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

export default DataResultsChart;
{{else}}
// AI NL Add-on is not enabled for this project
export {}
{{/if}}
