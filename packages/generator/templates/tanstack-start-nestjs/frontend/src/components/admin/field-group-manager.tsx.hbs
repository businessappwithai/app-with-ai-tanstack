/**
 * Field Group Manager Component
 *
 * Allows administrators to create and manage field groups for
 * multi-column layouts in forms. Groups are stored in sys_field.field_group.
 *
 * Features:
 * - Create custom field groups
 * - Assign fields to groups
 * - Reorder fields within groups
 * - Visual preview of group layout
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

'use client';

import { useState } from 'react';
import { useMutation, useQueryClient } from '@tanstack/react-query';
import { Plus, Trash2, GripVertical, X, Layers } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from '@/components/ui/dialog';
import { useFormFields } from '@/hooks/use-entities';
import { FieldMetadata } from '@/hooks/use-entities';
import { apiClient } from '@/lib/api-client';
import { toast } from 'sonner';

interface FieldGroupManagerProps {
  /** Entity/table name */
  entityName: string;
}

interface FieldGroup {
  name: string;
  fields: FieldMetadata[];
  columnSpan?: 1 | 2;
}

/**
 * Draggable field item component
 */
function DraggableField({
  field,
  onRemove,
}: {
  field: FieldMetadata;
  onRemove: (fieldId: string) => void;
}) {
  return (
    <div className="flex items-center gap-2 p-2 bg-background border rounded-md">
      <GripVertical className="h-4 w-4 text-muted-foreground cursor-grab" />
      <div className="flex-1 min-w-0">
        <div className="text-sm font-medium truncate">{field.name}</div>
        <div className="text-xs text-muted-foreground truncate">{field.column_name}</div>
      </div>
      <Button
        variant="ghost"
        size="sm"
        onClick={() => onRemove(field.sys_field_id)}
        className="h-6 w-6 p-0"
      >
        <X className="h-3 w-3" />
      </Button>
    </div>
  );
}

export function FieldGroupManager({ entityName }: FieldGroupManagerProps) {
  const queryClient = useQueryClient();
  const [groups, setGroups] = useState<FieldGroup[]>([]);
  const [selectedGroup, setSelectedGroup] = useState<string | null>(null);
  const [isCreatingGroup, setIsCreatingGroup] = useState(false);
  const [newGroupName, setNewGroupName] = useState('');
  const [availableFields, setAvailableFields] = useState<FieldMetadata[]>([]);
  const [assignedFields, setAssignedFields] = useState<FieldMetadata[]>([]);
  const [selectedFieldId, setSelectedFieldId] = useState<string | null>(null);
  const [columnSpan, setColumnSpan] = useState<1 | 2>(1);

  // Query form fields
  const { data: fields, isLoading } = useFormFields(entityName);

  // Update mutation
  const updateMutation = useMutation({
    mutationFn: async (updates: Array<{ id: string; field_group: string | null }>) => {
      await Promise.all(
        updates.map((update) =>
          apiClient.patch(`/api/sys/fields/${update.id}`, {
            field_group: update.field_group,
          })
        )
      );
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['entities', 'fields', entityName] });
      toast.success('Field groups updated successfully');
    },
    onError: () => {
      toast.error('Failed to update field groups');
    },
  });

  // Group fields by field_group when data loads
  useState(() => {
    if (fields && fields.length > 0) {
      const groupedFields = fields.reduce((acc, field) => {
        const groupName = field.field_group || 'ungrouped';
        if (!acc[groupName]) {
          acc[groupName] = [];
        }
        acc[groupName].push(field);
        return acc;
      }, {} as Record<string, FieldMetadata[]>);

      const groupList = Object.entries(groupedFields).map(([name, fields]) => ({
        name,
        fields: fields.sort((a, b) => a.seq_no - b.seq_no),
        columnSpan: 1,
      }));

      setGroups(groupList);

      // Set available fields (ungrouped)
      setAvailableFields(groupedFields['ungrouped'] || []);
      setAssignedFields([]);
    }
  });

  // Create new group
  const handleCreateGroup = () => {
    if (!newGroupName.trim()) {
      toast.error('Please enter a group name');
      return;
    }

    if (groups.some((g) => g.name === newGroupName)) {
      toast.error('Group already exists');
      return;
    }

    setGroups([...groups, { name: newGroupName, fields: [], columnSpan: 1 }]);
    setNewGroupName('');
    setIsCreatingGroup(false);
    setSelectedGroup(newGroupName);
    toast.success(`Group "${newGroupName}" created`);
  };

  // Delete group
  const handleDeleteGroup = (groupName: string) => {
    if (!confirm(`Delete group "${groupName}"? Fields will be moved to ungrouped.`)) {
      return;
    }

    const groupFields = groups.find((g) => g.name === groupName)?.fields || [];
    setAvailableFields([...availableFields, ...groupFields]);
    setGroups(groups.filter((g) => g.name !== groupName));

    if (selectedGroup === groupName) {
      setSelectedGroup(null);
      setAssignedFields([]);
    }
  };

  // Select group
  const handleSelectGroup = (groupName: string) => {
    setSelectedGroup(groupName);
    const group = groups.find((g) => g.name === groupName);
    setAssignedFields(group?.fields || []);
    setColumnSpan(group?.columnSpan || 1);
  };

  // Assign field to group
  const handleAssignField = () => {
    if (!selectedFieldId || !selectedGroup) return;

    const field = availableFields.find((f) => f.sys_field_id === selectedFieldId);
    if (!field) return;

    setAvailableFields(availableFields.filter((f) => f.sys_field_id !== selectedFieldId));
    setAssignedFields([...assignedFields, field]);
    setSelectedFieldId(null);

    // Update group
    setGroups(
      groups.map((g) =>
        g.name === selectedGroup ? { ...g, fields: [...g.fields, field] } : g
      )
    );
  };

  // Remove field from group
  const handleRemoveField = (fieldId: string) => {
    const field = assignedFields.find((f) => f.sys_field_id === fieldId);
    if (!field) return;

    setAssignedFields(assignedFields.filter((f) => f.sys_field_id !== fieldId));
    setAvailableFields([...availableFields, field]);

    // Update group
    setGroups(
      groups.map((g) =>
        g.name === selectedGroup
          ? { ...g, fields: g.fields.filter((f) => f.sys_field_id !== fieldId) }
          : g
      )
    );
  };

  // Save all changes
  const handleSave = () => {
    const updates: Array<{ id: string; field_group: string | null }> = [];

    groups.forEach((group) => {
      group.fields.forEach((field, index) => {
        updates.push({
          id: field.sys_field_id,
          field_group: group.name === 'ungrouped' ? null : group.name,
        });
      });
    });

    // Ungrouped fields
    availableFields.forEach((field) => {
      updates.push({
        id: field.sys_field_id,
        field_group: null,
      });
    });

    updateMutation.mutate(updates);
  };

  if (isLoading) {
    return (
      <Card>
        <CardContent className="p-12">
          <div className="flex items-center justify-center">
            <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-gray-900" />
          </div>
        </CardContent>
      </Card>
    );
  }

  return (
    <Card>
      <CardHeader>
        <div className="flex items-center justify-between">
          <div>
            <CardTitle>Field Group Manager</CardTitle>
            <CardDescription>
              Organize fields into groups for multi-column form layouts
            </CardDescription>
          </div>
          <Button onClick={handleSave} disabled={updateMutation.isPending}>
            {updateMutation.isPending ? 'Saving...' : 'Save Groups'}
          </Button>
        </div>
      </CardHeader>
      <CardContent>
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* Groups list */}
          <div className="space-y-4">
            <div className="flex items-center justify-between">
              <h3 className="font-semibold">Groups</h3>
              <Dialog open={isCreatingGroup} onOpenChange={setIsCreatingGroup}>
                <DialogTrigger asChild>
                  <Button size="sm" variant="outline">
                    <Plus className="h-4 w-4 mr-1" />
                    New Group
                  </Button>
                </DialogTrigger>
                <DialogContent>
                  <DialogHeader>
                    <DialogTitle>Create New Group</DialogTitle>
                    <DialogDescription>
                      Enter a name for the new field group
                    </DialogDescription>
                  </DialogHeader>
                  <div className="space-y-4 py-4">
                    <div>
                      <Label htmlFor="group-name">Group Name</Label>
                      <Input
                        id="group-name"
                        value={newGroupName}
                        onChange={(e) => setNewGroupName(e.target.value)}
                        placeholder="e.g., Contact Info"
                      />
                    </div>
                  </div>
                  <DialogFooter>
                    <Button variant="outline" onClick={() => setIsCreatingGroup(false)}>
                      Cancel
                    </Button>
                    <Button onClick={handleCreateGroup}>Create</Button>
                  </DialogFooter>
                </DialogContent>
              </Dialog>
            </div>

            <div className="space-y-2">
              {groups.map((group) => (
                <div
                  key={group.name}
                  className={`flex items-center gap-2 p-3 border rounded-lg cursor-pointer transition-colors ${
                    selectedGroup === group.name
                      ? 'bg-primary/10 border-primary'
                      : 'hover:bg-muted'
                  }`}
                  onClick={() => handleSelectGroup(group.name)}
                >
                  <Layers className="h-4 w-4 text-muted-foreground" />
                  <div className="flex-1 min-w-0">
                    <div className="font-medium truncate">{group.name}</div>
                    <div className="text-xs text-muted-foreground">
                      {group.fields.length} field(s)
                    </div>
                  </div>
                  {group.name !== 'ungrouped' && (
                    <Button
                      variant="ghost"
                      size="sm"
                      onClick={(e) => {
                        e.stopPropagation();
                        handleDeleteGroup(group.name);
                      }}
                      className="h-6 w-6 p-0"
                    >
                      <Trash2 className="h-3 w-3" />
                    </Button>
                  )}
                </div>
              ))}
            </div>
          </div>

          {/* Available fields */}
          <div className="space-y-4">
            <h3 className="font-semibold">Available Fields</h3>
            <div className="space-y-2">
              {availableFields.length === 0 ? (
                <div className="text-sm text-muted-foreground text-center py-4">
                  All fields are grouped
                </div>
              ) : (
                availableFields.map((field) => (
                  <div
                    key={field.sys_field_id}
                    className={`p-2 border rounded-md cursor-pointer transition-colors ${
                      selectedFieldId === field.sys_field_id
                        ? 'bg-primary/10 border-primary'
                        : 'hover:bg-muted'
                    }`}
                    onClick={() => setSelectedFieldId(field.sys_field_id)}
                  >
                    <div className="text-sm font-medium">{field.name}</div>
                    <div className="text-xs text-muted-foreground">{field.column_name}</div>
                  </div>
                ))
              )}
            </div>
            {selectedFieldId && selectedGroup && (
              <Button onClick={handleAssignField} className="w-full">
                Add to "{selectedGroup}"
              </Button>
            )}
          </div>

          {/* Selected group fields */}
          <div className="space-y-4">
            <div className="flex items-center justify-between">
              <h3 className="font-semibold">
                {selectedGroup ? `Group: ${selectedGroup}` : 'Select a group'}
              </h3>
              {selectedGroup && selectedGroup !== 'ungrouped' && (
                <Select value={String(columnSpan)} onValueChange={(v) => setColumnSpan(Number(v) as 1 | 2)}>
                  <SelectTrigger className="w-24">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="1">1 Col</SelectItem>
                    <SelectItem value="2">2 Col</SelectItem>
                  </SelectContent>
                </Select>
              )}
            </div>

            <div className="space-y-2">
              {assignedFields.length === 0 ? (
                <div className="text-sm text-muted-foreground text-center py-4">
                  No fields in this group
                </div>
              ) : (
                assignedFields.map((field) => (
                  <div key={field.sys_field_id} className="p-2 bg-background border rounded-md">
                    <div className="flex items-center gap-2">
                      <GripVertical className="h-4 w-4 text-muted-foreground cursor-grab" />
                      <div className="flex-1 min-w-0">
                        <div className="text-sm font-medium truncate">{field.name}</div>
                        <div className="text-xs text-muted-foreground truncate">{field.column_name}</div>
                      </div>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => handleRemoveField(field.sys_field_id)}
                        className="h-6 w-6 p-0"
                      >
                        <X className="h-3 w-3" />
                      </Button>
                    </div>
                  </div>
                ))
              )}
            </div>

            {/* Preview */}
            {selectedGroup && assignedFields.length > 0 && (
              <div className="pt-4 border-t">
                <h4 className="text-sm font-medium mb-2">Preview</h4>
                <div className={`grid gap-2 ${columnSpan === 2 ? 'grid-cols-2' : 'grid-cols-1'}`}>
                  {assignedFields.map((field) => (
                    <div key={field.sys_field_id} className="p-2 bg-muted rounded text-xs">
                      {field.name}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </CardContent>
    </Card>
  );
}
