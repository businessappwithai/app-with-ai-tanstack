/**
 * Field Grouping and Layout E2E Tests
 *
 * Comprehensive end-to-end tests for field grouping, multi-column layouts,
 * and field styling features.
 */

import { test, expect } from '@playwright/test';

// Test data for field groups
const TEST_GROUPS = {
  personalInfo: {
    name: 'Personal Information',
    description: 'Patient personal details',
    columns: 2,
  },
  systemInfo: {
    name: 'System Information',
    description: 'System maintained fields',
    columns: 1,
  },
};

const FIELD_COLORS = {
  blue: '#3b82f6',
  red: '#ef4444',
  green: '#22c55e',
  orange: '#f59e0b',
};

test.describe('Field Group Management', () => {
  test.beforeEach(async ({ page }) => {
    // Navigate to field layout manager
    await page.goto('/admin/fields');
    await page.waitForLoadState('networkidle');
  });

  test('should display field groups tab', async ({ page }) => {
    // Select PATIENT entity
    await page.selectOption('select', 'bus_p_a_t_i_e_n_t');

    // Check that Field Groups tab exists
    const groupsTab = page.getByRole('tab', { name: /field groups/i });
    await expect(groupsTab).toBeVisible();
  });

  test('should display existing field groups', async ({ page }) => {
    await page.selectOption('select', 'bus_p_a_t_i_e_n_t');
    await page.click('button:has-text("Field Groups")');

    // Wait for groups to load
    await page.waitForTimeout(500);

    // Check for Personal Information group
    await expect(page.getByText('Personal Information')).toBeVisible();
    await expect(page.getByText('Patient personal details')).toBeVisible();

    // Check for System Information group
    await expect(page.getByText('System Information')).toBeVisible();
  });

  test('should create a new field group', async ({ page }) => {
    await page.selectOption('select', 'bus_d_o_c_t_o_r');
    await page.click('button:has-text("Field Groups")');

    // Click Add Group button
    await page.click('button:has-text("Add Group")');

    // Fill in group details
    await page.fill('input[type="text"]', 'Contact Details');
    await page.fill('textarea', 'Doctor contact information');

    // Select 2-column layout
    await page.click('button:has-text("2 Columns")');

    // Save group
    await page.click('button:has-text("Save Group")');

    // Wait for save to complete
    await page.waitForTimeout(1000);

    // Verify group was created
    await expect(page.getByText('Contact Details')).toBeVisible();
    await expect(page.getByText('Doctor contact information')).toBeVisible();
  });

  test('should edit existing field group', async ({ page }) => {
    await page.selectOption('select', 'bus_p_a_t_i_e_n_t');
    await page.click('button:has-text("Field Groups")');

    // Wait for groups to load
    await page.waitForTimeout(500);

    // Click edit button on Personal Information group
    const editButton = page.locator('button[title="Edit group"]').first();
    await editButton.click();

    // Change name
    const nameInput = page.locator('input[type="text"]');
    await nameInput.fill('');
    await nameInput.fill('Personal Details (Updated)');

    // Save
    await page.click('button:has-text("Save Group")');

    // Wait for save
    await page.waitForTimeout(1000);

    // Verify update
    await expect(page.getByText('Personal Details (Updated)')).toBeVisible();
  });

  test('should delete field group with confirmation', async ({ page }) => {
    await page.selectOption('select', 'bus_p_a_t_i_e_n_t');
    await page.click('button:has-text("Field Groups")');
    await page.waitForTimeout(500);

    // Get initial group count
    const initialGroups = await page.locator('[data-testid="field-group-card"]').count();

    // Click delete on System Information group
    const deleteButtons = page.locator('button[title="Delete group"]');
    await deleteButtons.nth(1).click();

    // Handle confirmation dialog
    page.on('dialog', dialog => dialog.accept());
    await page.waitForTimeout(500);

    // Verify group was deleted
    const finalGroups = await page.locator('[data-testid="field-group-card"]').count();
    expect(finalGroups).toBeLessThan(initialGroups);
  });

  test('should display group column layout correctly', async ({ page }) => {
    await page.selectOption('select', 'bus_p_a_t_i_e_n_t');
    await page.click('button:has-text("Field Groups")');
    await page.waitForTimeout(500);

    // Check Personal Information has 2 columns badge
    const personalGroup = page.getByText('Personal Information').locator('..').locator('..');
    await expect(personalGroup.getByText('2 columns')).toBeVisible();

    // Check System Information has 1 column badge
    const systemGroup = page.getByText('System Information').locator('..').locator('..');
    await expect(systemGroup.getByText('1 column')).toBeVisible();
  });
});

test.describe('Field Layout Editor - Styling', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/admin/fields');
    await page.waitForLoadState('networkidle');
    await page.selectOption('select', 'bus_p_a_t_i_e_n_t');
  });

  test('should display expandable styling controls', async ({ page }) => {
    // Click on first field's expand button
    const expandButton = page.locator('button').filter({ hasText: /show styling options/i }).first();
    await expandButton.click();

    // Verify column span control is visible
    await expect(page.getByText('Column Span:')).toBeVisible();
    await expect(page.locator('input[type="range"]')).toBeVisible();

    // Verify color picker is visible
    await expect(page.getByText('Color:')).toBeVisible();
    await expect(page.locator('button[title="Auto"]')).toBeVisible();
  });

  test('should update field column span', async ({ page }) => {
    // Expand first field
    const expandButton = page.locator('button').filter({ hasText: /show styling options/i }).first();
    await expandButton.click();

    // Get current column span value
    const spanValue = page.locator('text=1').first();

    // Drag the slider
    const slider = page.locator('input[type="range"]').first();
    await slider.fill('6');

    // Wait for update
    await page.waitForTimeout(500);

    // Verify value changed (may need to re-expand)
    await page.waitForTimeout(1000);
  });

  test('should update field color', async ({ page }) => {
    // Expand first field
    const expandButton = page.locator('button').filter({ hasText: /show styling options/i }).first();
    await expandButton.click();

    // Click blue color option
    await page.click('button[title="Blue"]');

    // Wait for update
    await page.waitForTimeout(500);

    // Verify success message
    await expect(page.getByText('Field color updated')).toBeVisible();
  });

  test('should display group badges for grouped fields', async ({ page }) => {
    // Wait for fields to load
    await page.waitForTimeout(500);

    // Check that fields in Personal Information group have the badge
    const groupBadges = page.getByRole('button', { name: /Personal Information/i });
    await expect(groupBadges.first()).toBeVisible();

    // Check badge icon
    await expect(page.locator('.lucide-layers').first()).toBeVisible();
  });
});

test.describe('Dynamic Form - Grouped Rendering', () => {
  test.beforeEach(async ({ page }) => {
    // Navigate to patient create page
    await page.goto('/bus_p_a_t_i_e_n_t/new');
    await page.waitForLoadState('networkidle');
  });

  test('should display field groups as sections', async ({ page }) => {
    // Check for Personal Information section header
    await expect(page.getByText('Personal Information')).toBeVisible();

    // Check for System Information section
    await expect(page.getByText('System Information')).toBeVisible();
  });

  test('should display fields in multi-column layout', async ({ page }) => {
    // Personal Information should have 2-column layout
    const personalSection = page.getByText('Personal Information').locator('..');
    const formContainer = personalSection.locator('..').locator('..');

    // Check that grid is applied (verify by checking class)
    const grid = formContainer.locator('.grid');
    await expect(grid).toBeVisible();
  });

  test('should apply field colors correctly', async ({ page }) => {
    // This test requires that a field has been set with a custom color
    // For now, we just verify the form renders without errors
    await expect(page.getByText('Name')).toBeVisible();
    await expect(page.getByText('Phone')).toBeVisible();
  });

  test('should maintain field order within groups', async ({ page }) => {
    // Get all visible field labels
    const fields = page.getByTestId('field-label').all();

    // Verify that fields appear in expected order
    // Personal Information: Name, Phone, Email, Date of Birth
    await expect(page.getByText('Name')).toBeVisible();
    const phoneField = page.getByText('Phone');
    const emailField = page.getByText('Email');

    // Verify Phone appears before Email
    const phonePosition = await phoneField.boundingBox();
    const emailPosition = await emailField.boundingBox();

    if (phonePosition && emailPosition) {
      expect(phonePosition.y).toBeLessThan(emailPosition.y);
    }
  });
});

test.describe('Field Grouping API Integration', () => {
  test('should fetch field groups via API', async ({ request }) => {
    const response = await request.get('/api/bus/bus_p_a_t_i_e_n_t/field-groups');

    expect(response.status()).toBe(200);

    const data = await response.json();
    expect(data).toHaveProperty('data');
    expect(Array.isArray(data.data)).toBe(true);

    // Check for expected groups
    const groups = data.data;
    const personalInfo = groups.find((g: any) => g.name === 'Personal Information');
    expect(personalInfo).toBeDefined();
    expect(personalInfo.columns).toBe(2);
  });

  test('should fetch fields with group information', async ({ request }) => {
    const response = await request.get('/api/bus/bus_p_a_t_i_e_n_t/fields/form/all');

    expect(response.status()).toBe(200);

    const data = await response.json();
    expect(data.data).toBeDefined();

    // Check that fields have group properties
    const nameField = data.data.find((f: any) => f.column_name === 'name');
    expect(nameField).toHaveProperty('group_name');
    expect(nameField.group_name).toBe('Personal Information');
  });

  test('should create field group via API', async ({ request }) => {
    const newGroup = {
      name: 'Test Group',
      description: 'Test description',
      columns: 3,
      layout_type: 'three-column',
    };

    const response = await request.post('/api/bus/bus_p_a_t_i_e_n_t/field-groups', {
      data: newGroup,
    });

    expect(response.status()).toBe(201);
    const data = await response.json();
    expect(data.name).toBe('Test Group');
  });

  test('should update field style via API', async ({ request }) => {
    // First, get a field ID
    const fieldsResponse = await request.get('/api/bus/bus_p_a_t_i_e_n_t/fields/form/all');
    const fieldsData = await fieldsResponse.json();
    const firstField = fieldsData.data[0];

    // Update field color and column span
    const styleUpdate = {
      color: '#ef4444',
      col_span: 6,
    };

    const response = await request.patch(
      `/api/bus/bus_p_a_t_i_e_n_t/fields/${firstField.sys_field_id}/style`,
      { data: styleUpdate }
    );

    expect(response.status()).toBe(200);
  });
});

test.describe('Field Grouping - Responsive Design', () => {
  test('should collapse to single column on mobile', async ({ page }) => {
    await page.goto('/bus_p_a_t_i_e_n_t/new');
    await page.waitForLoadState('networkidle');

    // Set mobile viewport
    await page.setViewportSize({ width: 375, height: 667 });

    // Verify grid collapses to single column
    const formGrid = page.locator('.grid');
    await expect(formGrid).toBeVisible();

    // Check that it has responsive class
    const gridClasses = await formGrid.getAttribute('class');
    expect(gridClasses).toContain('grid-cols-1');
  });

  test('should show multi-column layout on desktop', async ({ page }) => {
    await page.goto('/bus_p_a_t_i_e_n_t/new');
    await page.waitForLoadState('networkidle');

    // Set desktop viewport
    await page.setViewportSize({ width: 1280, height: 720 });

    // Verify multi-column grid
    const formGrid = page.locator('.grid');
    await expect(formGrid).toBeVisible();

    // Check for responsive multi-column classes
    const gridClasses = await formGrid.getAttribute('class');
    expect(gridClasses).toMatch(/md:grid-cols-[2-4]/);
  });
});
