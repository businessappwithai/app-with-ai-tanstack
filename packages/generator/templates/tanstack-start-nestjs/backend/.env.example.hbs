# {{project.name}} - Backend Configuration
# Generated: {{now}}

# Server
PORT={{config.port}}
NODE_ENV=development

# Main Application Database
{{#if (eq config.databaseType 'postgresql')}}
DATABASE_CLIENT=pg
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME={{snakeCase project.name}}
DATABASE_USER={{config.dbUser}}
DATABASE_PASSWORD=
{{else}}
DATABASE_CLIENT=better-sqlite3
DATABASE_FILENAME=./data/{{snakeCase project.name}}.db
{{/if}}

# BetterAuth Authentication Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER={{config.dbUser}}
DB_PASSWORD=
# BetterAuth will use {{snakeCase project.name}}_auth database

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Rate Limiting
# Default: 10 requests per minute
# Can be overridden per controller with @Throttle() decorator

# Session Configuration
# BetterAuth session expires in 1 day (86400 seconds)
