# {{project.name}} - Backend Configuration
# Generated: {{now}}

# Server
PORT={{config.port}}
NODE_ENV=development

# Database (PostgreSQL)
# Uses local socket auth by default — no password needed on most dev machines
DATABASE_URL=postgresql://localhost/{{snakeCase project.name}}

# Alternatively, set individual vars (used when DATABASE_URL is not set):
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER={{snakeCase project.name}}
# DB_PASSWORD=
# DB_NAME={{snakeCase project.name}}

# CORS
CORS_ORIGIN=http://localhost:{{config.frontendPort}}

# Admin user (auto-created on first start)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=debug

# Immudb (cryptographic audit trail) — set to true if you have immudb running
IMMUDB_ENABLED=false
IMMUDB_HOST=127.0.0.1
IMMUDB_PORT=8088

# Session Configuration
# BetterAuth session expires in 1 day (86400 seconds)
BETTER_AUTH_SECRET=change-me-in-production-use-a-long-random-string
