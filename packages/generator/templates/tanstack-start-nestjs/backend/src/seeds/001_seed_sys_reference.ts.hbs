/**
 * Seed Application Dictionary Reference Data
 *
 * Populates sys_reference with standard field types.
 * These are the core reference types used throughout the system.
 *
 * Generated: {{now}}
 */

import { Knex } from 'knex';

export async function seed(knex: Knex): Promise<void> {
  // ========================================
  // Standard Reference Types
  // ========================================

  const references = [
    // String types
    {
      name: 'String',
      description: 'Simple text input field',
      reference_type: 'String',
      is_active: true,
    },
    {
      name: 'Text',
      description: 'Multi-line text area',
      reference_type: 'Text',
      is_active: true,
    },
    {
      name: 'URL',
      description: 'URL hyperlink field',
      reference_type: 'URL',
      validation_regex: '^https?://.+',
      is_active: true,
    },
    {
      name: 'Email',
      description: 'Email address field',
      reference_type: 'Email',
      validation_regex: '^[\\w\\.-]+@[\\w\\.-]+\\.\\w+$',
      is_active: true,
    },
    {
      name: 'Phone',
      description: 'Phone number field',
      reference_type: 'Phone',
      is_active: true,
    },

    // Numeric types
    {
      name: 'Integer',
      description: 'Whole number field',
      reference_type: 'Integer',
      is_active: true,
    },
    {
      name: 'Amount',
      description: 'Decimal/currency amount field',
      reference_type: 'Number',
      is_active: true,
    },
    {
      name: 'Quantity',
      description: 'Quantity field (decimal)',
      reference_type: 'Number',
      is_active: true,
    },

    // Boolean
    {
      name: 'Yes/No',
      description: 'Boolean yes/no choice',
      reference_type: 'Boolean',
      is_active: true,
    },

    // Date/Time
    {
      name: 'Date',
      description: 'Date field (no time)',
      reference_type: 'Date',
      is_active: true,
    },
    {
      name: 'Date+Time',
      description: 'Date and time field',
      reference_type: 'DateTime',
      is_active: true,
    },
    {
      name: 'Time',
      description: 'Time field (no date)',
      reference_type: 'Time',
      is_active: true,
    },

    // Identifiers
    {
      name: 'UUID',
      description: 'UUID identifier field',
      reference_type: 'UUID',
      validation_regex: '^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$',
      is_active: true,
    },
    {
      name: 'ID',
      description: 'Numeric ID field',
      reference_type: 'Integer',
      is_active: true,
    },

    // References (Foreign Keys)
    {
      name: 'Table Direct',
      description: 'Direct foreign key reference to another table',
      reference_type: 'TableDir',
      is_active: true,
    },
    {
      name: 'Table',
      description: 'Foreign key reference via a foreign key column',
      reference_type: 'Table',
      is_active: true,
    },
    {
      name: 'Search',
      description: 'Search field with popup dialog',
      reference_type: 'Search',
      is_active: true,
    },

    // Lists
    {
      name: 'List',
      description: 'Dropdown list from sys_ref_list',
      reference_type: 'List',
      is_active: true,
    },
    {
      name: 'Button',
      description: 'Button that triggers an action',
      reference_type: 'Button',
      is_active: true,
    },

    // Advanced types
    {
      name: 'Location',
      description: 'Geographic location (address, coordinates)',
      reference_type: 'Location',
      is_active: true,
    },
    {
      name: 'Account',
      description: 'Financial account reference',
      reference_type: 'Account',
      is_active: true,
    },
    {
      name: 'Attribute',
      description: 'Product attribute reference',
      reference_type: 'Attribute',
      is_active: true,
    },
    {
      name: 'Image',
      description: 'Image upload field',
      reference_type: 'Image',
      is_active: true,
    },
    {
      name: 'File',
      description: 'File upload field',
      reference_type: 'File',
      is_active: true,
    },
    {
      name: 'JSON',
      description: 'JSON object field',
      reference_type: 'JSON',
      is_active: true,
    },
    {
      name: 'Color',
      description: 'Color picker field',
      reference_type: 'Color',
      is_active: true,
    },
    {
      name: 'Rich Text',
      description: 'Rich text editor (HTML/Markdown)',
      reference_type: 'RichText',
      is_active: true,
    },
    {
      name: 'Password',
      description: 'Password input field (hashed)',
      reference_type: 'Password',
      is_active: true,
    },
    {
      name: 'Rating',
      description: 'Star rating field',
      reference_type: 'Rating',
      is_active: true,
    },
    {
      name: 'Tag',
      description: 'Tag/multi-select field',
      reference_type: 'Tag',
      is_active: true,
    },
  ];

  // Insert reference types
  for (const ref of references) {
    await knex('sys_reference')
      .insert({
        ...ref,
        created_at: new Date(),
        updated_at: new Date(),
      })
      .onConflict('name')
      .ignore();
  }

  console.log(`✓ Seeded ${references.length} reference types`);

  // ========================================
  // Seed Common List Values
  // ========================================

  // Get the List reference type
  const listRef = await knex('sys_reference')
    .where('name', 'List')
    .first();

  if (listRef) {
    // Create common list definitions
    const lists = [
      {
        name: 'Yes/No List',
        values: [
          { value: 'Y', name: 'Yes', seq_no: 10 },
          { value: 'N', name: 'No', seq_no: 20 },
        ],
      },
      {
        name: 'Active Status',
        values: [
          { value: 'Y', name: 'Active', seq_no: 10 },
          { value: 'N', name: 'Inactive', seq_no: 20 },
        ],
      },
      {
        name: 'Order Status',
        values: [
          { value: 'DRAFT', name: 'Draft', seq_no: 10 },
          { value: 'PENDING', name: 'Pending', seq_no: 20 },
          { value: 'PROCESSING', name: 'Processing', seq_no: 30 },
          { value: 'COMPLETED', name: 'Completed', seq_no: 40 },
          { value: 'CANCELLED', name: 'Cancelled', seq_no: 50 },
          { value: 'CLOSED', name: 'Closed', seq_no: 60 },
        ],
      },
      {
        name: 'Document Status',
        values: [
          { value: 'DRAFT', name: 'Draft', seq_no: 10 },
          { value: 'SUBMITTED', name: 'Submitted', seq_no: 20 },
          { value: 'APPROVED', name: 'Approved', seq_no: 30 },
          { value: 'REJECTED', name: 'Rejected', seq_no: 40 },
          { value: 'FINAL', name: 'Final', seq_no: 50 },
          { value: 'VOID', name: 'Void', seq_no: 60 },
        ],
      },
      {
        name: 'Payment Terms',
        values: [
          { value: 'IMMEDIATE', name: 'Immediate', seq_no: 10 },
          { value: 'NET_7', name: 'Net 7 Days', seq_no: 20 },
          { value: 'NET_15', name: 'Net 15 Days', seq_no: 30 },
          { value: 'NET_30', name: 'Net 30 Days', seq_no: 40 },
          { value: 'NET_60', name: 'Net 60 Days', seq_no: 50 },
          { value: 'NET_90', name: 'Net 90 Days', seq_no: 60 },
          { value: 'EOM_30', name: 'End of Month + 30 Days', seq_no: 70 },
        ],
      },
      {
        name: 'Currency',
        values: [
          { value: 'USD', name: 'US Dollar ($)', seq_no: 10 },
          { value: 'EUR', name: 'Euro (€)', seq_no: 20 },
          { value: 'GBP', name: 'British Pound (£)', seq_no: 30 },
          { value: 'JPY', name: 'Japanese Yen (¥)', seq_no: 40 },
          { value: 'CAD', name: 'Canadian Dollar (C$)', seq_no: 50 },
          { value: 'AUD', name: 'Australian Dollar (A$)', seq_no: 60 },
          { value: 'INR', name: 'Indian Rupee (₹)', seq_no: 70 },
        ],
      },
      {
        name: 'Priority',
        values: [
          { value: '1', name: 'Urgent', seq_no: 10 },
          { value: '2', name: 'High', seq_no: 20 },
          { value: '3', name: 'Medium', seq_no: 30 },
          { value: '4', name: 'Low', seq_no: 40 },
          { value: '5', name: 'Minimal', seq_no: 50 },
        ],
      },
      {
        name: 'User Level',
        values: [
          { value: 'S', name: 'System', seq_no: 10 },
          { value: 'C', name: 'Client', seq_no: 20 },
          { value: 'O', name: 'Organization', seq_no: 30 },
        ],
      },
    ];

    for (const list of lists) {
      // Create a reference for this list
      const [listRefId] = await knex('sys_reference')
        .insert({
          name: list.name,
          description: `${list.name} dropdown list`,
          reference_type: 'List',
          is_active: true,
          created_at: new Date(),
          updated_at: new Date(),
        })
        .returning('sys_reference_id');

      // Insert list values
      for (const item of list.values) {
        await knex('sys_ref_list')
          .insert({
            reference_id: listRefId,
            value: item.value,
            name: item.name,
            seq_no: item.seq_no,
            is_active: true,
            created_at: new Date(),
            updated_at: new Date(),
          })
          .onConflict(['reference_id', 'value'])
          .ignore();
      }
    }

    console.log(`✓ Seeded ${lists.length} list definitions with values`);
  }

  // ========================================
  // Seed Validation Rules
  // ========================================

  const validationRules = [
    {
      name: 'Email Required',
      rule_type: 'format',
      rule_expression: '^[\\w\\.-]+@[\\w\\.-]+\\.\\w+$',
      error_message: 'Must be a valid email address',
    },
    {
      name: 'Positive Number',
      rule_type: 'range',
      rule_expression: 'value > 0',
      error_message: 'Value must be greater than zero',
    },
    {
      name: 'Non-negative',
      rule_type: 'range',
      rule_expression: 'value >= 0',
      error_message: 'Value cannot be negative',
    },
    {
      name: 'Future Date',
      rule_type: 'custom',
      rule_expression: 'value >= new Date()',
      error_message: 'Date must be in the future',
    },
    {
      name: 'Past Date',
      rule_type: 'custom',
      rule_expression: 'value <= new Date()',
      error_message: 'Date must be in the past',
    },
    {
      name: 'Not Empty',
      rule_type: 'required',
      rule_expression: 'value !== null && value !== ""',
      error_message: 'This field is required',
    },
  ];

  for (const rule of validationRules) {
    await knex('sys_val_rule')
      .insert({
        ...rule,
        is_active: true,
        created_at: new Date(),
        updated_at: new Date(),
      })
      .onConflict('name')
      .ignore();
  }

  console.log(`✓ Seeded ${validationRules.length} validation rules`);

  console.log('✓ Application Dictionary reference data seeded successfully');
}
