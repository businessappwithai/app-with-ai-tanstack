/**
 * Seed Default Admin User and Roles
 *
 * Creates the default administrator account and system roles.
 * IMPORTANT: Change the default password after first login!
 *
 * Generated: {{now}}
 */

import { Knex } from 'knex';
import * as bcrypt from 'bcrypt';

export async function seed(knex: Knex): Promise<void> {
  // ========================================
  // Create System Roles
  // ========================================

  const roles = [
    {
      name: 'System Administrator',
      description: 'Full system access with all permissions',
      is_admin: true,
      user_level: 'S',
    },
    {
      name: 'Administrator',
      description: 'Administrative access to all modules',
      is_admin: true,
      user_level: 'C',
    },
    {
      name: 'User',
      description: 'Standard user access',
      is_admin: false,
      user_level: 'O',
    },
    {
      name: 'Read Only',
      description: 'Read-only access to data',
      is_admin: false,
      user_level: 'O',
    },
  ];

  const createdRoles: any[] = [];

  for (const role of roles) {
    const [roleData] = await knex('sys_role')
      .insert({
        ...role,
        is_active: true,
        created_at: new Date(),
        updated_at: new Date(),
      })
      .returning('*')
      .onConflict('name')
      .ignore();

    if (roleData) {
      createdRoles.push(roleData);
    }
  }

  console.log(`✓ Seeded ${createdRoles.length} system roles`);

  // ========================================
  // Create Default Admin User
  // ========================================

  // Default credentials
  const defaultEmail = 'admin@{{project.domain}}';
  const defaultPassword = 'admin123'; // IMPORTANT: Change after first login!

  // Hash password
  const passwordHash = await bcrypt.hash(defaultPassword, 10);

  // Create admin user
  const [adminUser] = await knex('sys_user')
    .insert({
      name: 'System Administrator',
      email: defaultEmail,
      password_hash: passwordHash,
      description: 'Default system administrator account',
      is_active: true,
      is_locked: false,
      created_at: new Date(),
      updated_at: new Date(),
    })
    .returning('*')
    .onConflict('email')
    .ignore();

  if (adminUser) {
    console.log(`✓ Created default admin user: ${defaultEmail} / ${defaultPassword}`);

    // Assign System Administrator role to admin user
    const systemAdminRole = createdRoles.find((r) => r.name === 'System Administrator');

    if (systemAdminRole) {
      await knex('sys_user_roles')
        .insert({
          user_id: adminUser.sys_user_id,
          role_id: systemAdminRole.sys_role_id,
          is_active: true,
          created_at: new Date(),
          updated_at: new Date(),
        })
        .onConflict(['user_id', 'role_id'])
        .ignore();

      console.log(`✓ Assigned 'System Administrator' role to admin user`);
    }
  } else {
    console.log('⚠ Admin user already exists, skipping creation');
  }

  // ========================================
  // Create Sample Users (optional)
  // ========================================

  const sampleUsers = [
    {
      name: 'John Manager',
      email: 'john.manager@{{project.domain}}',
      password: 'manager123',
      role: 'Administrator',
    },
    {
      name: 'Jane User',
      email: 'jane.user@{{project.domain}}',
      password: 'user123',
      role: 'User',
    },
  ];

  for (const sample of sampleUsers) {
    // Check if user already exists
    const existing = await knex('sys_user')
      .where('email', sample.email)
      .first();

    if (!existing) {
      const hashedPassword = await bcrypt.hash(sample.password, 10);

      const [user] = await knex('sys_user')
        .insert({
          name: sample.name,
          email: sample.email,
          password_hash: hashedPassword,
          is_active: true,
          is_locked: false,
          created_at: new Date(),
          updated_at: new Date(),
        })
        .returning('*');

      // Assign role
      const role = createdRoles.find((r) => r.name === sample.role);
      if (role && user) {
        await knex('sys_user_roles')
          .insert({
            user_id: user.sys_user_id,
            role_id: role.sys_role_id,
            is_active: true,
            created_at: new Date(),
            updated_at: new Date(),
          })
          .onConflict(['user_id', 'role_id'])
          .ignore();

        console.log(`✓ Created sample user: ${sample.email} / ${sample.password}`);
      }
    }
  }

  // ========================================
  // Grant Full Access to Admin Role
  // ========================================

  const systemAdminRole = createdRoles.find((r) => r.name === 'System Administrator');

  if (systemAdminRole) {
    // Get all sys_table records
    const tables = await knex('sys_table').select('sys_table_id');

    // Grant full access to all tables for System Administrator
    for (const table of tables) {
      await knex('sys_access')
        .insert({
          role_id: systemAdminRole.sys_role_id,
          table_id: table.sys_table_id,
          access_type: 'ALL',
          can_read: true,
          can_write: true,
          can_delete: true,
          created_at: new Date(),
          updated_at: new Date(),
        })
        .onConflict(['role_id', 'table_id'])
        .merge({
          can_read: true,
          can_write: true,
          can_delete: true,
          updated_at: new Date(),
        });
    }

    console.log(`✓ Granted full access to ${tables.length} tables for System Administrator role`);
  }

  console.log('✓ Admin user and roles seeded successfully');
  console.log('');
  console.log('⚠ IMPORTANT: Default admin credentials:');
  console.log(`   Email: ${defaultEmail}`);
  console.log(`   Password: ${defaultPassword}`);
  console.log('   Please change the password after first login!');
  console.log('');
}
