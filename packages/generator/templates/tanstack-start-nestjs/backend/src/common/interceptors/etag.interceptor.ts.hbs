/**
 * ETag Interceptor for Optimistic Concurrency Control
 *
 * Generated: {{now}}
 */

import {
  Injectable,
  NestInterceptor,
  ExecutionContext,
  CallHandler,
  PreconditionFailedException,
} from '@nestjs/common';
import { Observable } from 'rxjs';
import { map } from 'rxjs/operators';
import { FastifyReply, FastifyRequest } from 'fastify';
import * as crypto from 'crypto';

@Injectable()
export class EtagInterceptor implements NestInterceptor {
  intercept(context: ExecutionContext, next: CallHandler): Observable<any> {
    const request = context.switchToHttp().getRequest<FastifyRequest>();
    const response = context.switchToHttp().getResponse<FastifyReply>();

    return next.handle().pipe(
      map((data) => {
        if (!data) return data;

        // Generate ETag from response data
        const etag = this.generateEtag(data);
        response.header('ETag', `"${etag}"`);

        // Handle If-None-Match (GET caching)
        const ifNoneMatch = request.headers['if-none-match'];
        if (request.method === 'GET' && ifNoneMatch === `"${etag}"`) {
          response.status(304);
          return null;
        }

        // Handle If-Match (PUT/PATCH concurrency)
        const ifMatch = request.headers['if-match'];
        if (
          (request.method === 'PUT' || request.method === 'PATCH') &&
          ifMatch &&
          data.version !== undefined
        ) {
          const expectedVersion = this.extractVersionFromEtag(ifMatch);
          if (expectedVersion !== null && data.version !== expectedVersion) {
            throw new PreconditionFailedException(
              'Resource has been modified by another user',
            );
          }
        }

        return data;
      }),
    );
  }

  private generateEtag(data: any): string {
    // Use version if available, otherwise hash the content
    if (data.version !== undefined) {
      return `v${data.version}`;
    }

    const content = JSON.stringify(data);
    return crypto.createHash('md5').update(content).digest('hex').substring(0, 16);
  }

  private extractVersionFromEtag(etag: string): number | null {
    // Remove quotes and 'v' prefix
    const cleaned = etag.replace(/"/g, '').replace(/^v/, '');
    const version = parseInt(cleaned, 10);
    return isNaN(version) ? null : version;
  }
}
