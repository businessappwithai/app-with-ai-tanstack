{{#if config.aiNlAddon}}
/**
 * AI Controller
 *
 * REST API endpoints for AI Natural Language data queries.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import {
  Controller,
  Post,
  Body,
  UseGuards,
  HttpCode,
  HttpStatus,
  Request,
} from '@nestjs/common';
import { AIService, QueryResult } from './ai.service';
import { AuthGuard } from '../../common/guards/auth.guard';

// ============================================================================
// DTOs
// ============================================================================

class QueryRequestDto {
  query: string;
}

class QueryResponseDto {
  success: boolean;
  data: Record<string, unknown>[];
  count: number;
  entity: string;
  query: string;
  displayHint: 'table' | 'chart' | 'number';
  executionTimeMs: number;
  summary: string;
}

// ============================================================================
// Controller
// ============================================================================

@Controller('api/ai')
export class AIController {
  constructor(private readonly aiService: AIService) {}

  /**
   * Execute a natural language query
   *
   * POST /api/ai/query
   */
  @Post('query')
  @UseGuards(AuthGuard)
  @HttpCode(HttpStatus.OK)
  async executeQuery(
    @Body() dto: QueryRequestDto,
    @Request() req: { user: { id: string; sessionId: string } }
  ): Promise<QueryResponseDto> {
    const result = await this.aiService.executeQuery({
      query: dto.query,
      userId: req.user.id,
      sessionId: req.user.sessionId,
    });

    return result;
  }

  /**
   * CopilotKit runtime endpoint
   *
   * POST /api/copilotkit
   */
  @Post('/copilotkit')
  @UseGuards(AuthGuard)
  @HttpCode(HttpStatus.OK)
  async copilotkit(
    @Body() body: unknown,
    @Request() req: { user: { id: string; sessionId: string } }
  ) {
    // CopilotKit runtime handler
    return this.aiService.handleCopilotKitRequest(body, req.user);
  }

  /**
   * Get available entities for querying
   *
   * GET /api/ai/entities
   */
  @Post('entities')
  @UseGuards(AuthGuard)
  @HttpCode(HttpStatus.OK)
  async getEntities(
    @Request() req: { user: { id: string } }
  ) {
    const entities = await this.aiService.getAccessibleEntities(req.user.id);
    return { entities };
  }
}
{{else}}
// AI NL Add-on is not enabled for this project
export {}
{{/if}}
