/**
 * AI Service
 *
 * Business logic for AI Natural Language data queries.
 * Orchestrates the query workflow using Mastra.ai.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Injectable, Inject, Logger } from '@nestjs/common';
import type { Knex } from 'knex';
import { executeDataQuery, DataQueryWorkflowResult } from '../../common/ai/workflows/data-query-workflow';
import { RBACService } from '../../common/services/rbac.service';

// ============================================================================
// Types
// ============================================================================

export interface QueryInput {
  query: string;
  userId: string;
  sessionId: string;
}

export interface QueryResult {
  success: boolean;
  data: Record<string, unknown>[];
  count: number;
  entity: string;
  query: string;
  displayHint: 'table' | 'chart' | 'number';
  executionTimeMs: number;
  summary: string;
}

export interface EntityInfo {
  name: string;
  tableName: string;
  description?: string;
  fieldCount: number;
}

// ============================================================================
// Service
// ============================================================================

@Injectable()
export class AIService {
  private readonly logger = new Logger(AIService.name);

  constructor(
    @Inject('KNEX_CONNECTION') private readonly db: Knex,
    private readonly rbacService: RBACService
  ) {}

  /**
   * Execute a natural language query
   */
  async executeQuery(input: QueryInput): Promise<QueryResult> {
    this.logger.log(`Executing AI query: "${input.query}" for user ${input.userId}`);

    try {
      const result = await executeDataQuery(
        this.db,
        input,
        {
          log: async (entry) => {
            // Log to audit table
            await this.db('sys_audit_log').insert({
              sys_user_id: input.userId,
              event_type: entry.type,
              query: entry.query,
              error: entry.errors ? JSON.stringify(entry.errors) : null,
              created_at: new Date(),
            });
          },
        }
      );

      this.logger.log(`Query completed: ${result.count} results in ${result.executionTimeMs}ms`);
      return result;
    } catch (error) {
      this.logger.error(`Query failed: ${error.message}`, error.stack);

      // Log failure
      await this.db('sys_audit_log').insert({
        sys_user_id: input.userId,
        event_type: 'query_failure',
        query: input.query,
        error: error.message,
        created_at: new Date(),
      });

      throw error;
    }
  }

  /**
   * Handle CopilotKit runtime requests
   */
  async handleCopilotKitRequest(
    body: unknown,
    user: { id: string; sessionId: string }
  ): Promise<unknown> {
    // Process CopilotKit actions
    const request = body as {
      action?: string;
      parameters?: Record<string, unknown>;
    };

    if (request.action === 'queryData' && request.parameters?.query) {
      const result = await this.executeQuery({
        query: request.parameters.query as string,
        userId: user.id,
        sessionId: user.sessionId,
      });

      return {
        type: 'response',
        data: result,
      };
    }

    return { type: 'unknown' };
  }

  /**
   * Get entities accessible to a user
   */
  async getAccessibleEntities(userId: string): Promise<EntityInfo[]> {
    const permissions = await this.rbacService.getUserPermissions(userId);

    // Get all business tables
    const tables = await this.db('sys_table')
      .where('table_name', 'like', 'bus_%')
      .where('is_active', true)
      .select('sys_table_id', 'table_name', 'name', 'description');

    const accessibleEntities: EntityInfo[] = [];

    for (const table of tables) {
      // Check if user has read access
      const tablePermission = permissions.tablePermissions.get(table.table_name.toLowerCase());
      if (!tablePermission?.canRead) continue;

      // Count visible fields
      const fieldCount = await this.db('sys_field')
        .where('sys_table_id', table.sys_table_id)
        .where('is_active', true)
        .count('* as count')
        .first();

      accessibleEntities.push({
        name: table.name,
        tableName: table.table_name,
        description: table.description,
        fieldCount: Number(fieldCount?.count || 0),
      });
    }

    return accessibleEntities;
  }

  /**
   * Check if a user can use AI queries
   */
  async canUseAIQueries(userId: string): Promise<boolean> {
    const permissions = await this.rbacService.getUserPermissions(userId);
    // User needs at least one table with read access
    return Array.from(permissions.tablePermissions.values()).some(p => p.canRead);
  }
}
{{else}}
// AI NL Add-on is not enabled for this project
export {}
{{/if}}
