import { Injectable, NotFoundException } from '@nestjs/common';
import { DatabaseService } from '../../database/service';

@Injectable()
export class SysTabService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; windowId?: string } = {}) {
    const { page = 1, limit = 100, windowId } = options;
    const offset = (page - 1) * limit;

    let query = this.db.knex('sys_tab').where('is_active', true);

    if (windowId) {
      query = query.where('sys_window_id', windowId);
    }

    const [data, countResult] = await Promise.all([
      query.clone().orderBy('seq_no').limit(limit).offset(offset),
      query.clone().count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const tab = await this.db.knex('sys_tab').where('sys_tab_id', id).first();
    if (!tab) {
      throw new NotFoundException(`SysTab with ID ${id} not found`);
    }
    return tab;
  }

  async create(data: any) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_tab_id: id,
      ...data,
      tab_level: data.tab_level || 0,
      seq_no: data.seq_no || 0,
      is_single_row: data.is_single_row === true,
      has_tree: data.has_tree === true,
      is_info_tab: data.is_info_tab === true,
      is_translation_tab: data.is_translation_tab === true,
      is_read_only: data.is_read_only === true,
      is_insert_record: data.is_insert_record !== false,
      is_advanced_tab: data.is_advanced_tab === true,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_tab').insert(newRecord);
    return this.findById((newRecord.sys_tab_id as any).toString());
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.knex('sys_tab').where('sys_tab_id', id).update(updated);
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_tab').where('sys_tab_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }

  async getFields(tabId: string, view?: 'form' | 'grid') {
    return this.db.knex('sys_field')
      .select('sys_field.*', 'sys_column.column_name')
      .leftJoin('sys_column', 'sys_field.sys_column_id', 'sys_column.sys_column_id')
      .where('sys_field.sys_tab_id', tabId)
      .where('sys_field.is_active', true)
      .where(view === 'grid' ? 'sys_field.is_displayed_grid' : 'sys_field.is_displayed', true)
      .orderBy(view === 'grid' ? 'sys_field.seq_no_grid' : 'sys_field.seq_no');
  }
}
