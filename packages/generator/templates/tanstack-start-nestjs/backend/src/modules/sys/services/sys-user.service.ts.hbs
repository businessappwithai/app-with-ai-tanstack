import { Injectable, NotFoundException } from '@nestjs/common';
import { DatabaseService } from '../../database/service';

@Injectable()
export class SysUserService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number } = {}) {
    const { page = 1, limit = 100 } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.knex('sys_user').where('is_active', true).orderBy('name').limit(limit).offset(offset),
      this.db.knex('sys_user').where('is_active', true).count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const user = await this.db.knex('sys_user').where('sys_user_id', id).first();
    if (!user) {
      throw new NotFoundException(`SysUser with ID ${id} not found`);
    }
    return user;
  }

  async findByEmail(email: string) {
    const user = await this.db.knex('sys_user').where('email', email).first();
    if (!user) {
      throw new NotFoundException(`User with email ${email} not found`);
    }
    return user;
  }

  async create(data: any) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_user_id: id,
      ...data,
      is_system_user: data.is_system_user === true,
      is_sales_rep: data.is_sales_rep === true,
      login_failure_count: data.login_failure_count || 0,
      is_locked: data.is_locked === true,
      is_account_verified: data.is_account_verified === true,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_user').insert(newRecord);
    return this.findById((newRecord.sys_user_id as any).toString());
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.knex('sys_user').where('sys_user_id', id).update(updated);
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_user').where('sys_user_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }

  async getRoles(userId: string) {
    return this.db.knex('sys_user_roles')
      .select('sys_role.*')
      .join('sys_role', 'sys_user_roles.sys_role_id', 'sys_role.sys_role_id')
      .where('sys_user_roles.sys_user_id', userId)
      .where('sys_user_roles.is_active', true)
      .where('sys_role.is_active', true);
  }
}
