import { Injectable, NotFoundException } from '@nestjs/common';
import { DatabaseService } from '../../database/service';

@Injectable()
export class SysWindowService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number } = {}) {
    const { page = 1, limit = 100 } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.knex('sys_window').where('is_active', true).orderBy('name').limit(limit).offset(offset),
      this.db.knex('sys_window').where('is_active', true).count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const window = await this.db.knex('sys_window').where('sys_window_id', id).first();
    if (!window) {
      throw new NotFoundException(`SysWindow with ID ${id} not found`);
    }
    return window;
  }

  async create(data: any) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_window_id: id,
      ...data,
      window_type: data.window_type || 'M',
      is_sales_transaction: data.is_sales_transaction === true,
      is_default: data.is_default !== false,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_window').insert(newRecord);
    return this.findById((newRecord.sys_window_id as any).toString());
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.knex('sys_window').where('sys_window_id', id).update(updated);
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_window').where('sys_window_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }

  async getTabs(windowId: string) {
    return this.db.knex('sys_tab')
      .where('sys_window_id', windowId)
      .where('is_active', true)
      .orderBy('seq_no');
  }
}
