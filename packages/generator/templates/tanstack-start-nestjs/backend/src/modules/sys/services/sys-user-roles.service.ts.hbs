import { Injectable, NotFoundException } from '@nestjs/common';
import { DatabaseService } from '../../database/service';

@Injectable()
export class SysUserRolesService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; userId?: string; roleId?: string } = {}) {
    const { page = 1, limit = 100, userId, roleId } = options;
    const offset = (page - 1) * limit;

    let query = this.db.knex('sys_user_roles')
      .select('sys_user_roles.*')
      .where('is_active', true);

    if (userId) {
      query = query.where('sys_user_id', userId);
    }

    if (roleId) {
      query = query.where('sys_role_id', roleId);
    }

    const [data, countResult] = await Promise.all([
      query.clone().orderBy('created_at', 'desc').limit(limit).offset(offset),
      query.clone().count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const userRole = await this.db.knex('sys_user_roles').where('sys_user_roles_id', id).first();
    if (!userRole) {
      throw new NotFoundException(`SysUserRole with ID ${id} not found`);
    }
    return userRole;
  }

  async create(data: any) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_user_roles_id: id,
      ...data,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_user_roles').insert(newRecord);
    return this.findById((newRecord.sys_user_roles_id as any).toString());
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.knex('sys_user_roles').where('sys_user_roles_id', id).update(updated);
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_user_roles').where('sys_user_roles_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }
}
