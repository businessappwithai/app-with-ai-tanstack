import { Injectable, NotFoundException } from '@nestjs/common';
import { DatabaseService } from '../../database/service';

@Injectable()
export class SysRefListService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; referenceId?: number } = {}) {
    const { page = 1, limit = 100, referenceId } = options;
    const offset = (page - 1) * limit;

    let query = this.db.knex('sys_ref_list').where('is_active', true);

    if (referenceId) {
      query = query.where('sys_reference_id', referenceId);
    }

    const [data, countResult] = await Promise.all([
      query.clone().orderBy('value').limit(limit).offset(offset),
      query.clone().count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const refList = await this.db.knex('sys_ref_list').where('sys_ref_list_id', id).first();
    if (!refList) {
      throw new NotFoundException(`SysRefList with ID ${id} not found`);
    }
    return refList;
  }

  async create(data: any) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_ref_list_id: id,
      ...data,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_ref_list').insert(newRecord);
    return this.findById((newRecord.sys_ref_list_id as any).toString());
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.knex('sys_ref_list').where('sys_ref_list_id', id).update(updated);
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_ref_list').where('sys_ref_list_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }
}
