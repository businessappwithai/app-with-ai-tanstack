import { Controller, Get, Post, Delete, Body, Param, Query, UseGuards } from '@nestjs/common';
import { ApiTags, ApiOperation, ApiBearerAuth } from '@nestjs/swagger';
import { SysUserRolesService } from '../services/sys-user-roles.service';
import { JwtAuthGuard } from '../../common/guards/jwt-auth.guard';

@ApiTags('sys-user-roles')
@ApiBearerAuth()
@UseGuards(JwtAuthGuard)
@Controller('sys/user-roles')
export class SysUserRolesController {
  constructor(private readonly sysUserRolesService: SysUserRolesService) {}

  @Get()
  @ApiOperation({ summary: 'List all sys_user_roles records' })
  async findAll(
    @Query('page') page?: string,
    @Query('limit') limit?: string,
    @Query('userId') userId?: string,
    @Query('roleId') roleId?: string,
  ) {
    return this.sysUserRolesService.findAll({
      page: page ? parseInt(page, 10) : undefined,
      limit: limit ? parseInt(limit, 10) : undefined,
      userId,
      roleId,
    });
  }

  @Get(':id')
  @ApiOperation({ summary: 'Get sys_user_roles by ID' })
  async findOne(@Param('id') id: string) {
    return this.sysUserRolesService.findById(id);
  }

  @Post()
  @ApiOperation({ summary: 'Assign role to user' })
  async create(@Body() data: any) {
    return this.sysUserRolesService.create(data);
  }

  @Delete(':id')
  @ApiOperation({ summary: 'Remove role from user' })
  async delete(@Param('id') id: string) {
    return this.sysUserRolesService.delete(id);
  }

  @Delete('user/:userId/role/:roleId')
  @ApiOperation({ summary: 'Remove specific role from user' })
