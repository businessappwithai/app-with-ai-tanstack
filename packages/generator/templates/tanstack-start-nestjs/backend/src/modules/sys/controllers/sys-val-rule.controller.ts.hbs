import { Controller, Get, Post, Put, Patch, Delete, Body, Param, Query, UseGuards } from '@nestjs/common';
import { ApiTags, ApiOperation, ApiBearerAuth } from '@nestjs/swagger';
import { SysValRuleService } from '../services/sys-val-rule.service';
import { JwtAuthGuard } from '../../common/guards/jwt-auth.guard';

@ApiTags('sys-val-rule')
@ApiBearerAuth()
@UseGuards(JwtAuthGuard)
@Controller('sys/val-rules')
export class SysValRuleController {
  constructor(private readonly sysValRuleService: SysValRuleService) {}

  @Get()
  @ApiOperation({ summary: 'List all sys_val_rule records' })
  async findAll(
    @Query('page') page?: string,
    @Query('limit') limit?: string,
  ) {
    return this.sysValRuleService.findAll({
      page: page ? parseInt(page, 10) : undefined,
      limit: limit ? parseInt(limit, 10) : undefined,
    });
  }

  @Get(':id')
  @ApiOperation({ summary: 'Get sys_val_rule by ID' })
  async findOne(@Param('id') id: string) {
    return this.sysValRuleService.findById(id);
  }

  @Post()
  @ApiOperation({ summary: 'Create new sys_val_rule' })
  async create(@Body() data: any) {
    return this.sysValRuleService.create(data);
  }

  @Put(':id')
  @ApiOperation({ summary: 'Update sys_val_rule' })
  async update(@Param('id') id: string, @Body() data: any) {
    return this.sysValRuleService.update(id, data);
  }

  @Patch(':id')
  @ApiOperation({ summary: 'Partial update sys_val_rule' })
  async partialUpdate(@Param('id') id: string, @Body() data: any) {
    return this.sysValRuleService.update(id, data);
  }

  @Delete(':id')
  @ApiOperation({ summary: 'Delete sys_val_rule' })
  async delete(@Param('id') id: string) {
    return this.sysValRuleService.delete(id);
  }
}
