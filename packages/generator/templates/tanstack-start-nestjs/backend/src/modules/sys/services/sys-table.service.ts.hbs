import { Injectable } from '@nestjs/common';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysTableService {
  constructor(private readonly db: DatabaseService) {}

  /**
   * Find all sys_table records with pagination
   */
  async findAll(options: { page?: number; limit?: number; search?: string; isActive?: boolean } = {}) {
    const { page = 1, limit = 100, search, isActive = true } = options;
    const offset = (page - 1) * limit;

    let query = this.db.knex('sys_table').select('*');

    if (isActive !== undefined) {
      query = query.where('is_active', isActive);
    }

    if (search) {
      query = query.where(function() {
        this.where('name', 'like', `%${search}%`)
          .orWhere('table_name', 'like', `%${search}%`)
          .orWhere('description', 'like', `%${search}%`);
      });
    }

    const [data, countResult] = await Promise.all([
      query.clone().orderBy('name').limit(limit).offset(offset),
      query.clone().count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  /**
   * Find sys_table by ID
   */
  async findById(id: string) {
    const table = await this.db.knex('sys_table').where('sys_table_id', id).first();
    if (!table) {
      throw new Error(`SysTable with ID ${id} not found`);
    }
    return table;
  }

  /**
   * Find sys_table by table_name
   */
  async findByTableName(tableName: string) {
    const table = await this.db.knex('sys_table').where('table_name', tableName).first();
    if (!table) {
      throw new Error(`Table ${tableName} not found in sys_table`);
    }
    return table;
  }

  /**
   * Create new sys_table
   */
  async create(data: {
    name: string;
    table_name: string;
    description?: string;
    table_type: 'system' | 'business';
    is_view?: boolean;
    access_level?: string;
    windowId?: string;
  }) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_table_id: id,
      ...data,
      is_active: true,
      is_view: data.is_view || false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_table').insert(newRecord);
    return this.findById((newRecord.sys_table_id as any).toString());
  }

  /**
   * Update sys_table
   */
  async update(id: string, data: {
    name?: string;
    description?: string;
    is_active?: boolean;
    access_level?: string;
  }) {
    const existing = await this.findById(id);

    const updated = {
      ...data,
      updated_at: new Date(),
    };

    await this.db.knex('sys_table').where('sys_table_id', id).update(updated);
    return this.findById(id);
  }

  /**
   * Delete (soft delete) sys_table
   */
  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_table').where('sys_table_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }

  /**
   * Get columns for a table
   */
  async getColumns(tableId: string) {
    return this.db.knex('sys_column')
      .where('sys_table_id', tableId)
      .where('is_active', true)
      .orderBy('seq_no');
  }
}
