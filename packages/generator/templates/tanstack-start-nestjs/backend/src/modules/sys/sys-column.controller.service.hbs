/**
 * SysColumn Service
 *
 * Manages sys_column entities - defines column metadata for all Application Dictionary tables.
 *
 * Generated: {{now}}
 */

import { Injectable, NotFoundException } from '@nestjs/common';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysColumnService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; tableId?: string } = {}) {
    const { page = 1, limit = 100, tableId } = options;
    const offset = (page - 1) * limit;

    let query = this.db.knex('sys_column').where('is_active', true);

    if (tableId) {
      query = query.where('sys_table_id', tableId);
    }

    const [data, countResult] = await Promise.all([
      query.clone().orderBy('seq_no').limit(limit).offset(offset),
      query.clone().count('* as count').first(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil((countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const column = await this.db.knex('sys_column').where('sys_column_id', id).first();
    if (!column) {
      throw new NotFoundException(`SysColumn with ID ${id} not found`);
    }
    return column;
  }

  async create(data: any) {
    const now = new Date();
    const id = this.db.knex.raw('UUID()');

    const newRecord = {
      sys_column_id: id,
      ...data,
      is_key: data.is_key === true,
      is_parent: data.is_parent === true,
      is_mandatory: data.is_mandatory === true,
      is_updateable: data.is_updateable !== false,
      is_identifier: data.is_identifier === true,
      is_selection_column: data.is_selection_column === true,
      seq_no: data.seq_no || 0,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.knex('sys_column').insert(newRecord);
    return this.findById((newRecord.sys_column_id as any).toString());
  }

  async update(id: string, data: any) {
    const updated = {
      ...data,
      updated_at: new Date(),
      updated_by: '',
    };

    await this.db.knex('sys_column').where('sys_column_id', id).update(updated);
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.knex('sys_column').where('sys_column_id', id).update({
      is_active: false,
      deleted_at: new Date(),
    });
    return { deleted: true };
  }
}
