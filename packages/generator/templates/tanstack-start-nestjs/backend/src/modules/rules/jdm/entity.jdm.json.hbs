{
  "nodes": [
    {
      "id": "input",
      "type": "inputNode",
      "name": "Input",
      "position": { "x": 0, "y": 0 }
    },
    {
      "id": "{{tableName}}-validation",
      "type": "decisionTableNode",
      "name": "{{displayName}} Validation",
      "position": { "x": 300, "y": 0 },
      "content": {
        "hitPolicy": "collect",
        "inputs": [
          {{#each attributes}}
          {{#unless (or (eq name "id") (eq name "created_at") (eq name "updated_at") (eq name "deleted_at") (eq name "version"))}}
          { "id": "i{{@index}}", "name": "{{displayName}}", "field": "{{columnName}}" },
          {{/unless}}
          {{/each}}
        ],
        "outputs": [
          { "id": "o1", "name": "Action", "field": "action" },
          { "id": "o2", "name": "Message", "field": "message" },
          { "id": "o3", "name": "Rule ID", "field": "ruleId" },
          { "id": "o4", "name": "Workflow Name", "field": "workflowName" }
        ],
        "rules": [
          {{#each attributes}}
          {{#unless (or (eq name "id") (eq name "created_at") (eq name "updated_at") (eq name "deleted_at") (eq name "version"))}}
          {{#if required}}
          {
            "_id": "{{../tableName}}-{{columnName}}-required",
            "i{{@index}}": "{{columnName}} == null",
            "o1": "'prevent'",
            "o2": "'{{displayName}} is required'",
            "o3": "'{{../tableName}}-{{columnName}}-required'",
            "o4": "''"
          },
          {{/if}}
          {{#if (eq type "decimal")}}
          {
            "_id": "{{../tableName}}-{{columnName}}-non-negative",
            "i{{@index}}": "{{columnName}} < 0",
            "o1": "'prevent'",
            "o2": "'{{displayName}} must not be negative'",
            "o3": "'{{../tableName}}-{{columnName}}-non-negative'",
            "o4": "''"
          },
          {{/if}}
          {{#if (eq columnName "email")}}
          {
            "_id": "{{../tableName}}-email-format",
            "i{{@index}}": "!contains(email, \"@\")",
            "o1": "'prevent'",
            "o2": "'Email must be a valid email address'",
            "o3": "'{{../tableName}}-email-format'",
            "o4": "''"
          },
          {{/if}}
          {{/unless}}
          {{/each}}
          {
            "_id": "{{tableName}}-on-create-trigger-workflow",
            "i0": "action == \"create\"",
            "o1": "'trigger-workflow'",
            "o2": "'{{displayName}} created — triggering post-create workflow'",
            "o3": "'{{tableName}}-on-create-trigger-workflow'",
            "o4": "'{{tableName}}-on-create-workflow'"
          },
          {
            "_id": "{{tableName}}-on-update-trigger-workflow",
            "i0": "action == \"update\"",
            "o1": "'trigger-workflow'",
            "o2": "'{{displayName}} updated — triggering post-update workflow'",
            "o3": "'{{tableName}}-on-update-trigger-workflow'",
            "o4": "'{{tableName}}-on-update-workflow'"
          }
        ]
      }
    },
    {
      "id": "output",
      "type": "outputNode",
      "name": "Output",
      "position": { "x": 600, "y": 0 }
    }
  ],
  "edges": [
    { "id": "e1", "sourceId": "input", "targetId": "{{tableName}}-validation" },
    { "id": "e2", "sourceId": "{{tableName}}-validation", "targetId": "output" }
  ]
}
