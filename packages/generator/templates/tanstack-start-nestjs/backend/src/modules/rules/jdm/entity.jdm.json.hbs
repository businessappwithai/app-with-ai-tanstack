{
  "nodes": [
    {
      "id": "input",
      "type": "inputNode",
      "name": "Input",
      "position": { "x": 0, "y": 0 }
    },
    {
      "id": "{{tableName}}-validation",
      "type": "decisionTableNode",
      "name": "{{displayName}} Validation",
      "position": { "x": 300, "y": 0 },
      "content": {
        "hitPolicy": "collect",
        "inputs": [
          {{#each attributes}}
          {{#unless (eq name "id")}}
          {{#if (eq type "string")}}
          { "id": "i{{@index}}", "name": "{{displayName}}", "field": "{{columnName}}" }{{#unless @last}},{{/unless}}
          {{/if}}
          {{/unless}}
          {{/each}}
        ],
        "outputs": [
          { "id": "o1", "name": "Action", "field": "action" },
          { "id": "o2", "name": "Message", "field": "message" },
          { "id": "o3", "name": "Rule ID", "field": "ruleId" }
        ],
        "rules": [
          {{#each attributes}}
          {{#unless (eq name "id")}}
          {{#if required}}
          {
            "_id": "{{../tableName}}-{{columnName}}-required",
            "i{{@index}}": "== null",
            "o1": "prevent",
            "o2": "{{displayName}} is required",
            "o3": "{{../tableName}}-{{columnName}}-required"
          }{{#unless @last}},{{/unless}}
          {{/if}}
          {{/unless}}
          {{/each}}
        ]
      }
    },
    {
      "id": "output",
      "type": "outputNode",
      "name": "Output",
      "position": { "x": 600, "y": 0 }
    }
  ],
  "edges": [
    { "id": "e1", "sourceId": "input", "targetId": "{{tableName}}-validation" },
    { "id": "e2", "sourceId": "{{tableName}}-validation", "targetId": "output" }
  ]
}
