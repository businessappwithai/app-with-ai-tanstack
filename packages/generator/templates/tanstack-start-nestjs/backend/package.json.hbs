{
  "name": "{{kebabCase project.name}}-backend",
  "version": "{{project.version}}",
  "description": "{{project.description}} - NestJS Backend",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/main.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun run dist/main",
    "lint": "biome lint --write src",
    "lint:fix": "biome lint --write src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "migrate": "bun run src/migrate.ts latest",
    "migrate:down": "bun run src/migrate.ts down",
    "db:setup": "bun run src/migrate.ts latest"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    {{#if config.enableSwagger}}
    "@nestjs/swagger": "^7.2.0",
    {{/if}}
    "@nestjs/throttler": "^6.5.0",
    "@fastify/static": "^6.12.0",
    "@gorules/zen-engine": "^0.54.0",
    "@trigger.dev/sdk": "^3.0.0",
    "better-auth": "^1.6.11",
    "@better-auth/kysely-adapter": "^1.6.11",
    "@better-auth/utils": "^0.4.0",
    "kysely": "^0.28.14",
    "pg": "^8.11.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "fastify": "^4.25.0",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "zod": "^3.25.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@biomejs/biome": "^1.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  }
}
