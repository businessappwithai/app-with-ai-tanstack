{
  "name": "{{kebabCase project.name}}-backend",
  "version": "{{project.version}}",
  "description": "{{project.description}} - NestJS Backend",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "bun run main.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun run dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "migrate": "knex migrate:latest",
    "migrate:make": "knex migrate:make",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "db:setup": "knex migrate:latest && knex seed:run"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    {{#if config.enableSwagger}}
    "@nestjs/swagger": "^7.2.0",
    {{/if}}
    "@nestjs/throttler": "^6.5.0",
    "@fastify/static": "^6.12.0",
    "@gorules/zen-engine": "^0.54.0",
    "@trigger.dev/sdk": "^3.0.0",
    "better-auth": "^1.5.6",
    "@better-auth/kysely-adapter": "^1.5.6",
    "@better-auth/utils": "^0.4.0",
    "kysely": "^0.28.14",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "fastify": "^4.25.0",
    "knex": "^3.1.0",
    {{#if (eq config.databaseType 'postgresql')}}
    "pg": "^8.20.0",
    {{else}}
    "better-sqlite3": "^9.4.0",
    {{/if}}
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "zod": "^3.22.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    {{#if (eq config.databaseType 'postgresql')}}
    "@types/pg": "^8.20.0",
    {{/if}}
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "better-sqlite3": "^9.4.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
