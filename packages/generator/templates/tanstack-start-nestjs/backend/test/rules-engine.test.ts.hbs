/**
 * Rules Engine Integration Tests
 *
 * Tests for the business rules evaluation service
 *
 * Generated: {{now}}
 */

import { describe, it, expect, beforeAll } from 'vitest';
import request from 'supertest';
import { AppModule } from '../src/app.module';
import {
  createTestApp,
  closeTestApp,
  initTestDatabase,
} from './setup';

describe('Rules Engine API', () => {
  let app: ReturnType<typeof createTestApp> extends Promise<infer T> ? T : never;

  beforeAll(async () => {
    await initTestDatabase();
    app = await createTestApp(AppModule);
  });

  afterAll(async () => {
    await closeTestApp(app);
  });

  describe('Rules Evaluation', () => {
    it('should evaluate rules for an entity', async () => {
      const response = await request(app.getHttpServer())
        .post('/api/rules/evaluate')
        .send({
          entityType: '{{#each entities}}{{#if @first}}{{tableName}}{{/if}}{{/each}}',
          data: {},
          action: 'create',
        })
        .expect(200);

      expect(response.body).toHaveProperty('results');
      expect(Array.isArray(response.body.results)).toBe(true);
    });
  });

  describe('Rules Validation API', () => {
    it('should validate data against rules', async () => {
      const response = await request(app.getHttpServer())
        .post('/api/rules/validate')
        .send({
          entityType: '{{#each entities}}{{#if @first}}{{tableName}}{{/if}}{{/each}}',
          data: {},
          action: 'create',
        })
        .expect(200);

      expect(response.body).toHaveProperty('valid');
      expect(typeof response.body.valid).toBe('boolean');
    });
  });

  describe('Entities List API', () => {
    it('should return list of entities with rules', async () => {
      const response = await request(app.getHttpServer())
        .get('/api/rules/entities')
        .expect(200);

      expect(response.body).toHaveProperty('entities');
      expect(Array.isArray(response.body.entities)).toBe(true);
      expect(response.body.entities.length).toBeGreaterThan(0);
    });
  });
});
