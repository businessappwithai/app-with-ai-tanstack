// ── Layer 3: WorkflowService.triggerByWorkflowName ────────────────────────────

describe('WorkflowService — triggerByWorkflowName executes BPMN and updates entities', () => {
  const ENTITY_ID = 'appt-uuid-abc';
  const WORKFLOW_DEF = {
    id: 'wf-def-1',
    name: 'GenerateClaimWorkflow',
    entity_name: 'bus_appointment',
    operation: 'ALL',
    bpmn_xml: UPDATE_ENTITY_BPMN,
    is_active: true,
    created_by: 'seed',
    created_at: new Date(),
  };
  const RUN_ROW = { id: 'run-uuid-1', status: 'draft' };

  it('executes UpdateEntity BPMN tasks and records a success run', async () => {
    const { chain: mockDb, updates, inserts } = createMockDb({
      selectOne: { sys_workflow_definitions: WORKFLOW_DEF },
      insert:    { sys_workflow_runs: RUN_ROW },
    });

    const wfSvc = new WorkflowService(mockDb);

    await wfSvc.triggerByWorkflowName(
      'GenerateClaimWorkflow',
      'bus_appointment',
      ENTITY_ID,
      'update',
      { id: ENTITY_ID, current_state: 'completed' },
    );

    // Verify a workflow run was inserted
    const runInsert = inserts.find((i) => i.table === 'sys_workflow_runs');
    expect(runInsert).toBeDefined();
    expect(runInsert!.values.entity_name).toBe('bus_appointment');
    expect(runInsert!.values.entity_id).toBe(ENTITY_ID);
    expect(runInsert!.values.operation).toBe('UPDATE');
    expect(runInsert!.values.status).toBe('draft');
    expect(runInsert!.values.created_by).toBe('rules-engine');

    // Verify UpdateEntity tasks ran (2 service tasks in BPMN)
    const entityUpdates = updates.filter((u) => u.table === 'bus_appointment');
    expect(entityUpdates.length).toBe(2);

    const docStatusUpdate = entityUpdates.find(
      (u) => (u.fields as any).doc_status !== undefined,
    );
    expect(docStatusUpdate).toBeDefined();
    expect((docStatusUpdate!.fields as any).doc_status).toBe('processing');

    const wfStatusUpdate = entityUpdates.find(
      (u) => (u.fields as any).workflow_status !== undefined,
    );
    expect(wfStatusUpdate).toBeDefined();
    expect((wfStatusUpdate!.fields as any).workflow_status).toBe('triggered');

    // Verify the run was updated to success
    const runUpdate = updates.find((u) => u.table === 'sys_workflow_runs');
    expect(runUpdate).toBeDefined();
    expect((runUpdate!.fields as any).status).toBe('success');
  });

  it('records an error run when the workflow definition is not found', async () => {
    const { chain: mockDb, updates } = createMockDb({
      selectOne: { sys_workflow_definitions: undefined },
    });

    const wfSvc = new WorkflowService(mockDb);

    // Should not throw — logs a warning and returns
    await expect(
      wfSvc.triggerByWorkflowName(
        'NonExistentWorkflow',
        'bus_appointment',
        ENTITY_ID,
        'update',
        { id: ENTITY_ID },
      ),
    ).resolves.toBeUndefined();

    // No run should be inserted since the definition was not found
    const runUpdate = updates.find((u) => u.table === 'sys_workflow_runs' && (u.fields as any).status === 'error');
    expect(runUpdate).toBeUndefined();
  });

  it('marks the run as error when executeBpmn throws', async () => {
    const BPMN_WITH_UNKNOWN_TASK = `<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:erdwithai="http://erdwithai.com/extensions">
  <bpmn:process id="TestWf" isExecutable="true">
    <bpmn:serviceTask id="t1" name="Update Missing Entity">
      <bpmn:extensionElements>
        <erdwithai:property name="nodeType" value="UpdateEntity"/>
        <erdwithai:property name="entity"   value="bus_appointment"/>
        <erdwithai:property name="field"    value="doc_status"/>
        <erdwithai:property name="value"    value="error-state"/>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
  </bpmn:process>
</bpmn:definitions>`;

    const BAD_DEF = { ...WORKFLOW_DEF, bpmn_xml: BPMN_WITH_UNKNOWN_TASK };

    const { chain: mockDb, updates } = createMockDb({
      selectOne: { sys_workflow_definitions: BAD_DEF },
      insert: { sys_workflow_runs: RUN_ROW },
    });

    const wfSvc = new WorkflowService(mockDb);

    await wfSvc.triggerByWorkflowName(
      'GenerateClaimWorkflow',
      'bus_appointment',
      ENTITY_ID,
      'update',
      { id: ENTITY_ID, current_state: 'completed' },
    );

    // doc_status update should still be attempted (entity has id in payload)
    const docUpdate = updates.find(
      (u) => u.table === 'bus_appointment' && (u.fields as any).doc_status === 'error-state',
    );
    expect(docUpdate).toBeDefined();
  });

  it('is idempotent — multiple calls with the same args each create separate run records', async () => {
    let insertCount = 0;
    const { chain: mockDb, inserts } = createMockDb({
      selectOne: { sys_workflow_definitions: WORKFLOW_DEF },
      insert: { sys_workflow_runs: { id: 'run-uuid-seq', status: 'draft' } },
    });

    // Override insert to count
    const origInsertInto = mockDb.insertInto.bind(mockDb);
    mockDb.insertInto = (table: string) => {
      if (table === 'sys_workflow_runs') insertCount++;
      return origInsertInto(table);
    };

    const wfSvc = new WorkflowService(mockDb);

    await wfSvc.triggerByWorkflowName('GenerateClaimWorkflow', 'bus_appointment', ENTITY_ID, 'update', { id: ENTITY_ID });
    await wfSvc.triggerByWorkflowName('GenerateClaimWorkflow', 'bus_appointment', ENTITY_ID, 'update', { id: ENTITY_ID });

    // Two separate run records inserted
    const runInserts = inserts.filter((i) => i.table === 'sys_workflow_runs');
    expect(runInserts.length).toBeGreaterThanOrEqual(2);
  });
});

// ── Layer 4: End-to-end chain ─────────────────────────────────────────────────

describe('End-to-end: rule fires → workflow runs → entity updated', () => {
  let engine: RulesEngine;

  const RULE_ROW = {
    id: 'rule-e2e',
    entity_name: 'bus_appointment',
    rule_name: 'appointment_completed_e2e',
    operation: 'ALL',
    jdm_content: TRIGGER_WORKFLOW_JDM,
    is_active: true,
  };
  const WORKFLOW_DEF = {
    id: 'wf-e2e',
    name: 'GenerateClaimWorkflow',
    entity_name: 'bus_appointment',
    operation: 'ALL',
    bpmn_xml: UPDATE_ENTITY_BPMN,
    is_active: true,
  };
  const RUN_ROW = { id: 'run-e2e-1', status: 'draft' };

  beforeAll(() => { engine = new RulesEngine(); });
  afterAll(() => { engine.onModuleDestroy(); });

  it('appointment state change triggers workflow that updates doc_status and workflow_status', async () => {
    const { chain: rulesDb } = createMockDb({
      select: { sys_rule_definitions: [RULE_ROW] },
    });

    // Shared update tracker for the workflow service
    const updatesApplied: Array<{ table: string; fields: Record<string, unknown> }> = [];
    const wfInserts: any[] = [];

    // Workflow service needs its own db (different queries)
    let wfCurrentOp = 'select';
    let wfCurrentTable = '';
    let wfPendingSet: Record<string, unknown> = {};
    let wfPendingValues: Record<string, unknown> = {};

    const wfMockDb: any = {};
    wfMockDb.selectFrom = (t: string) => { wfCurrentOp = 'select'; wfCurrentTable = t; return wfMockDb; };
    wfMockDb.insertInto = (t: string) => { wfCurrentOp = 'insert'; wfCurrentTable = t; return wfMockDb; };
    wfMockDb.updateTable = (t: string) => { wfCurrentOp = 'update'; wfCurrentTable = t; return wfMockDb; };
    for (const m of ['selectAll', 'where', 'orderBy', 'limit', 'returningAll']) {
      wfMockDb[m] = (..._a: any[]) => wfMockDb;
    }
    wfMockDb.set = (d: any) => { wfPendingSet = d; return wfMockDb; };
    wfMockDb.values = (d: any) => { wfPendingValues = d; return wfMockDb; };
    wfMockDb.execute = () => {
      if (wfCurrentOp === 'update') {
        updatesApplied.push({ table: wfCurrentTable, fields: { ...wfPendingSet } });
        wfPendingSet = {};
      }
      return Promise.resolve([]);
    };
    wfMockDb.executeTakeFirst = () => {
      if (wfCurrentOp === 'insert') {
        wfInserts.push({ table: wfCurrentTable, values: { ...wfPendingValues } });
        wfPendingValues = {};
        if (wfCurrentTable === 'sys_workflow_runs') return Promise.resolve(RUN_ROW);
      }
      if (wfCurrentOp === 'select') {
        if (wfCurrentTable === 'sys_workflow_definitions') return Promise.resolve(WORKFLOW_DEF);
      }
      return Promise.resolve(undefined);
    };

    const wfSvc = new WorkflowService(wfMockDb);
    const rulesSvc = new RulesService(engine, rulesDb, wfSvc);

    // Simulate an appointment being updated to 'completed'
    await rulesSvc.executeMatchedActions(
      'bus_appointment',
      'appt-e2e-id',
      { current_state: 'completed', id: 'appt-e2e-id' },
      'update',
    );

    // Workflow run was created
    expect(wfInserts.some((i) => i.table === 'sys_workflow_runs')).toBe(true);

    // UpdateEntity tasks updated bus_appointment fields
    const apptUpdates = updatesApplied.filter((u) => u.table === 'bus_appointment');
    expect(apptUpdates.length).toBe(2);

    const docUpdate = apptUpdates.find((u) => (u.fields as any).doc_status !== undefined);
    expect(docUpdate).toBeDefined();
    expect((docUpdate!.fields as any).doc_status).toBe('processing');

    const wfUpdate = apptUpdates.find((u) => (u.fields as any).workflow_status !== undefined);
    expect(wfUpdate).toBeDefined();
    expect((wfUpdate!.fields as any).workflow_status).toBe('triggered');

    // Run was marked success
    const successUpdate = updatesApplied.find(
      (u) => u.table === 'sys_workflow_runs' && (u.fields as any).status === 'success',
    );
    expect(successUpdate).toBeDefined();
  });

  it('non-triggering state change produces no workflow run', async () => {
    const { chain: rulesDb } = createMockDb({
      select: { sys_rule_definitions: [RULE_ROW] },
    });

    const wfCalls: string[] = [];
    const mockWfSvc = {
      triggerByWorkflowName: async (name: string) => { wfCalls.push(name); },
    } as unknown as WorkflowService;

    const rulesSvc = new RulesService(engine, rulesDb, mockWfSvc);

    await rulesSvc.executeMatchedActions(
      'bus_appointment',
      'appt-no-trigger',
      { current_state: 'scheduled', id: 'appt-no-trigger' },
      'update',
    );

    expect(wfCalls.length).toBe(0);
  });
});
