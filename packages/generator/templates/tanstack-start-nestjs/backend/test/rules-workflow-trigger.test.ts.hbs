      'bus_appointment',
      'appt-uuid-456',
      { current_state: 'scheduled', id: 'appt-uuid-456' },
      'update',
    );

    expect(calls.length).toBe(0);
  });

  it('does NOT call triggerByWorkflowName when there are no active rules', async () => {
    const { chain: mockDb } = createMockDb({
      select: { sys_rule_definitions: [] },
    });

    const calls: string[] = [];
    const mockWorkflowService = {
      triggerByWorkflowName: async (name: string) => { calls.push(name); },
    } as unknown as WorkflowService;

    const svc = new RulesService(engine, mockDb, mockWorkflowService);

    await svc.executeMatchedActions(
      'bus_appointment',
      'appt-uuid-789',
      { current_state: 'completed', id: 'appt-uuid-789' },
      'update',
    );

    expect(calls.length).toBe(0);
  });

  it('skips trigger-workflow when workflowName is missing from rule action', async () => {
    // JDM that returns trigger-workflow but without a workflowName output
    const JDM_NO_WF_NAME = JSON.stringify({
      nodes: [
        { id: 'input',  type: 'inputNode',  name: 'Input',  position: { x: 0, y: 0 } },
        {
          id: 'rule-node',
          type: 'decisionTableNode',
          name: 'Trigger Without Name',
          position: { x: 300, y: 0 },
