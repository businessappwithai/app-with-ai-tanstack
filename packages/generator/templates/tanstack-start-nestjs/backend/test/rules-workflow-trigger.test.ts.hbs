// ── Mock helpers ──────────────────────────────────────────────────────────────

/**
 * Builds a Kysely-compatible fluent chain mock.  Each selectFrom / insertInto /
 * updateTable call records the table name; execute() / executeTakeFirst() look
 * up the registered response for the most-recently-set context.
 */
function createMockDb(responses: {
  select?: Record<string, any[]>;
  selectOne?: Record<string, any>;
  insert?: Record<string, any>;
  update?: Record<string, void>;
}) {
  const updates: Array<{ table: string; fields: Record<string, unknown>; whereId: string | null }> = [];
  const inserts: Array<{ table: string; values: Record<string, unknown> }> = [];

  let currentOp   = 'select';
  let currentTable = '';
  let pendingSet: Record<string, unknown> = {};
  let pendingValues: Record<string, unknown> = {};

  const chain: any = {};

  chain.selectFrom = (table: string) => { currentOp = 'select'; currentTable = table; return chain; };
  chain.insertInto = (table: string) => { currentOp = 'insert'; currentTable = table; return chain; };
  chain.updateTable = (table: string) => { currentOp = 'update'; currentTable = table; return chain; };
  chain.deleteFrom  = (table: string) => { currentOp = 'delete'; currentTable = table; return chain; };

  // fluent no-op methods
  for (const m of ['selectAll', 'where', 'orderBy', 'limit', 'select', 'returningAll']) {
    chain[m] = (..._args: any[]) => chain;
  }

  chain.set = (data: Record<string, unknown>) => { pendingSet = data; return chain; };
  chain.values = (data: Record<string, unknown>) => { pendingValues = data; return chain; };

  chain.execute = () => {
    if (currentOp === 'update') {
      updates.push({ table: currentTable, fields: pendingSet, whereId: null });
      pendingSet = {};
    }
    if (currentOp === 'insert') {
      inserts.push({ table: currentTable, values: pendingValues });
      pendingValues = {};
    }
    const result = responses.select?.[currentTable] ?? [];
    return Promise.resolve(result);
  };

  chain.executeTakeFirst = () => {
    if (currentOp === 'insert') {
      const row = responses.insert?.[currentTable];
      inserts.push({ table: currentTable, values: pendingValues });
      pendingValues = {};
      return Promise.resolve(row);
    }
    const result = responses.selectOne?.[currentTable] ?? responses.select?.[currentTable]?.[0];
    return Promise.resolve(result ?? undefined);
  };

  return { chain, updates, inserts };
}

// ── Layer 1: RulesEngine ─────────────────────────────────────────────────────

describe('RulesEngine — trigger-workflow action', () => {
  let engine: RulesEngine;

  beforeAll(() => { engine = new RulesEngine(); });
  afterAll(() => { engine.onModuleDestroy(); });

  it('returns a trigger-workflow action when the appointment is completed', async () => {
    const data = { current_state: 'completed' };
    const results = await engine.evaluateRulesWithJDM('bus_appointment', TRIGGER_WORKFLOW_JDM, data, 'update');

    expect(results.length).toBe(1);
    const [result] = results;
    expect(result.matched).toBe(true);
    expect(result.actions[0].type).toBe('trigger-workflow');
    expect(result.actions[0].config.workflowName).toBe('GenerateClaimWorkflow');
    expect(result.actions[0].config.message).toContain('billing workflow');
  });

  it('returns no results when appointment state does not match the trigger condition', async () => {
    const data = { current_state: 'scheduled' };
    const results = await engine.evaluateRulesWithJDM('bus_appointment', TRIGGER_WORKFLOW_JDM, data, 'update');

    expect(results.length).toBe(0);
  });

  it('returns no results for a null current_state (non-triggering)', async () => {
    const data = { current_state: null };
    const results = await engine.evaluateRulesWithJDM('bus_appointment', TRIGGER_WORKFLOW_JDM, data, 'update');

    expect(results.length).toBe(0);
  });

  it('does NOT fire trigger-workflow for an unrelated silent JDM', async () => {
    const data = { current_state: 'completed' };
    const results = await engine.evaluateRulesWithJDM('bus_appointment', SILENT_JDM, data, 'update');

    expect(results.length).toBe(0);
  });

  it('carries workflowName in the action config — accessible downstream', async () => {
    const data = { current_state: 'completed' };
    const [result] = await engine.evaluateRulesWithJDM('bus_appointment', TRIGGER_WORKFLOW_JDM, data, 'update');

    const wfAction = result.actions.find((a) => a.type === 'trigger-workflow');
    expect(wfAction).toBeDefined();
    expect(typeof wfAction!.config.workflowName).toBe('string');
    expect((wfAction!.config.workflowName as string).length).toBeGreaterThan(0);
  });
});

