describe('RulesService — executeMatchedActions dispatches trigger-workflow', () => {
  let engine: RulesEngine;

  const RULE_ROW = {
    id: 'rule-1',
    entity_name: 'bus_appointment',
    rule_name: 'appointment_completed_rule',
    operation: 'ALL',
    jdm_content: TRIGGER_WORKFLOW_JDM,
    is_active: true,
    version: 1,
    created_by: 'test',
    created_at: new Date(),
    updated_at: new Date(),
  };

  beforeAll(() => { engine = new RulesEngine(); });
  afterAll(() => { engine.onModuleDestroy(); });

  it('calls workflowService.triggerByWorkflowName with the correct workflow name', async () => {
    const { chain: mockDb } = createMockDb({
      select: { sys_rule_definitions: [RULE_ROW] },
    });

    const calls: Array<{ name: string; entity: string; id: string }> = [];
    const mockWorkflowService = {
      triggerByWorkflowName: async (name: string, entity: string, id: string) => {
        calls.push({ name, entity, id });
      },
    } as unknown as WorkflowService;

    const svc = new RulesService(engine, mockDb, mockWorkflowService);

    await svc.executeMatchedActions(
      'bus_appointment',
      'appt-uuid-123',
      { current_state: 'completed', id: 'appt-uuid-123' },
      'update',
    );

    expect(calls.length).toBe(1);
    expect(calls[0].name).toBe('GenerateClaimWorkflow');
    expect(calls[0].entity).toBe('bus_appointment');
    expect(calls[0].id).toBe('appt-uuid-123');
  });

  it('does NOT call triggerByWorkflowName when the rule does not match', async () => {
    const { chain: mockDb } = createMockDb({
      select: { sys_rule_definitions: [RULE_ROW] },
    });

    const calls: string[] = [];
    const mockWorkflowService = {
      triggerByWorkflowName: async (name: string) => { calls.push(name); },
    } as unknown as WorkflowService;

    const svc = new RulesService(engine, mockDb, mockWorkflowService);

