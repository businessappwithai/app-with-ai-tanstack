/**
 * {{entity.name}} List Page
 *
 * Uses EntityWindowShell for consistent admin-style UX:
 * - Toolbar with New, Save, Delete, Undo, Refresh, Search
 * - List-first view with clickable rows
 * - Detail view with record navigation and Back to List
 * - Dynamic fields driven by sys_field metadata
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { createFileRoute, Outlet, useChildMatches } from '@tanstack/react-router';
import { EntityWindowShell } from '@/components/admin/entity-window-shell';

export const Route = createFileRoute('/{{entity.tableName}}')({
  component: EntityListWrapper,
});

function EntityListWrapper() {
  const childMatches = useChildMatches();
  if (childMatches.length > 0) return <Outlet />;
  return <EntityWindowShell tableName="{{entity.tableName}}" entityLabel="{{entity.name}}" />;
}
