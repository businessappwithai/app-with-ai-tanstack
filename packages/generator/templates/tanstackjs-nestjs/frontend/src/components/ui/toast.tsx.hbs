'use client';

import * as React from 'react';
import * as ToastPrimitives from '@radix-ui/react-toast';
import { X, CheckCircle2, AlertCircle, Info, AlertTriangle } from 'lucide-react';
import { cn } from '@/lib/utils';

const ToastProvider = ToastPrimitives.Provider;

const ToastViewport = React.forwardRef<
  React.ElementRef<typeof ToastPrimitives.Viewport>,
  React.ComponentPropsWithoutRef<typeof ToastPrimitives.Viewport>
>(({ className, ...props }, ref) => (
  <ToastPrimitives.Viewport
    ref={ref}
    className={cn(
      'fixed bottom-0 right-0 z-[100] flex max-h-screen w-full flex-col-reverse p-4 sm:max-w-[420px]',
      className
    )}
    {...props}
  />
));
ToastViewport.displayName = ToastPrimitives.Viewport.displayName;

const toastVariants = {
  default: 'border-slate-200 bg-white text-slate-950',
  destructive: 'border-red-500 bg-red-500 text-white',
  success: 'border-green-500 bg-green-50 text-green-900',
  warning: 'border-yellow-500 bg-yellow-50 text-yellow-900',
  info: 'border-blue-500 bg-blue-50 text-blue-900',
};

type ToastVariant = keyof typeof toastVariants;

const Toast = React.forwardRef<
  React.ElementRef<typeof ToastPrimitives.Root>,
  React.ComponentPropsWithoutRef<typeof ToastPrimitives.Root> & {
  variant?: ToastVariant;
  title?: string;
  referenceId?: string;
}
>(({ className, variant = 'default', title, referenceId, ...props }, ref) => {
  return (
    <ToastPrimitives.Root
      ref={ref}
      className={cn(
        'group pointer-events-auto relative flex w-full items-center justify-between space-x-4 overflow-hidden rounded-md border p-4 pr-8 shadow-lg transition-all data-[swipe=move]:translate-x-1 data-[swipe=cancel]:translate-x-0',
        toastVariants[variant],
        className
      )}
      {...props}
    >
      <div className="flex gap-3">
        {variant === 'success' && (
          <CheckCircle2 className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
        )}
        {variant === 'destructive' && (
          <AlertCircle className="h-5 w-5 text-white flex-shrink-0 mt-0.5" />
        )}
        {variant === 'warning' && (
          <AlertTriangle className="h-5 w-5 text-yellow-600 flex-shrink-0 mt-0.5" />
        )}
        {variant === 'info' && (
          <Info className="h-5 w-5 text-blue-600 flex-shrink-0 mt-0.5" />
        )}
        <div className="flex-1 flex flex-col gap-1">
          {title && (
            <div className="text-sm font-semibold">{title}</div>
          )}
          <ToastPrimitives.Description asChild>
            <div className="text-sm opacity-90">
              {props.children}
            </div>
          </ToastPrimitives.Description>
          {referenceId && (
            <div className="text-xs font-mono opacity-75 mt-1">
              Reference ID: {referenceId}
            </div>
          )}
        </div>
      </div>
      <ToastPrimitives.Close className="absolute right-2 top-2 rounded-md p-1 opacity-0 transition-opacity hover:bg-slate-100 focus:opacity-100">
        <X className="h-4 w-4" />
      </ToastPrimitives.Close>
    </ToastPrimitives.Root>
  );
});
Toast.displayName = ToastPrimitives.Root.displayName;

const ToastAction = React.forwardRef<
  React.ElementRef<typeof ToastPrimitives.Action>,
  React.ComponentPropsWithoutRef<typeof ToastPrimitives.Action>
>(({ className, ...props }, ref) => (
  <ToastPrimitives.Action
    ref={ref}
    className={cn(
      'inline-flex h-8 shrink-0 items-center justify-center rounded-md border bg-transparent px-3 text-sm font-medium ring-offset-background transition-colors hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-950 focus:ring-offset-2 disabled:pointer-events-none',
      className
    )}
    {...props}
  />
));
ToastAction.displayName = ToastPrimitives.Action.displayName;

// Simple toast hook
type ToastProps = {
  title?: string;
  description: string;
  variant?: ToastVariant;
  referenceId?: string;
  duration?: number;
};

type ToastFunction = (props: ToastProps) => number;
type ToastConvenience = (description: string, options?: { title?: string; referenceId?: string; duration?: number }) => number;

interface ToastWithHelpers extends ToastFunction {
  success: ToastConvenience;
  error: ToastConvenience;
  warning: ToastConvenience;
  info: ToastConvenience;
}

let toastCount = 0;
const toasts: Map<number, ToastProps> = new Map();

const toastBase: ToastFunction = function(props: ToastProps) {
  const id = toastCount++;
  toasts.set(id, { ...props, duration: props.duration || 5000 });

  // Force re-render if needed
  window.dispatchEvent(new CustomEvent('toast-added'));

  setTimeout(() => {
    toasts.delete(id);
    window.dispatchEvent(new CustomEvent('toast-removed'));
  }, props.duration || 5000);

  return id;
};

// Convenience methods for common toast types
const toast = toastBase as ToastWithHelpers;

toast.success = (description: string, options?: { title?: string; referenceId?: string; duration?: number }) => {
  return toast({
    title: options?.title || 'Success',
    description,
    variant: 'success',
    referenceId: options?.referenceId,
    duration: options?.duration,
  });
};

toast.error = (description: string, options?: { title?: string; referenceId?: string; duration?: number }) => {
  return toast({
    title: options?.title || 'Error',
    description,
    variant: 'destructive',
    referenceId: options?.referenceId,
    duration: options?.duration,
  });
};

toast.warning = (description: string, options?: { title?: string; referenceId?: string; duration?: number }) => {
  return toast({
    title: options?.title || 'Warning',
    description,
    variant: 'warning',
    referenceId: options?.referenceId,
    duration: options?.duration,
  });
};

toast.info = (description: string, options?: { title?: string; referenceId?: string; duration?: number }) => {
  return toast({
    title: options?.title || 'Info',
    description,
    variant: 'info',
    referenceId: options?.referenceId,
    duration: options?.duration,
  });
};

export { toast };

export function Toaster() {
  const [toastsList, setToastsList] = React.useState<ToastProps[]>([]);

  React.useEffect(() => {
    const handleToastAdded = () => {
      setToastsList(Array.from(toasts.values()));
    };
    const handleToastRemoved = () => {
      setToastsList(Array.from(toasts.values()));
    };

    window.addEventListener('toast-added', handleToastAdded);
    window.addEventListener('toast-removed', handleToastRemoved);

    return () => {
      window.removeEventListener('toast-added', handleToastAdded);
      window.removeEventListener('toast-removed', handleToastRemoved);
    };
  }, []);

  return (
    <ToastProvider>
      <ToastViewport>
        {toastsList.map((toast, index) => (
          <Toast
            key={index}
            variant={toast.variant}
            title={toast.title}
            referenceId={toast.referenceId}
          >
            {toast.description}
          </Toast>
        ))}
      </ToastViewport>
    </ToastProvider>
  );
}

export { Toast };
