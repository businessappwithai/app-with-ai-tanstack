{
  "_version": "2.0.0",
  "sap.app": {
    "id": "q-a-test-project",
    "type": "application",
    "title": "QA Test Project",
    "description": "Testing the project creation form",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "http://localhost:4013/odata/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://table-view"
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.uxap": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "q-a-test-project.i18n.i18n"
        }
      },
      "fcl": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "initialLayout": "OneColumn"
        },
        "preload": true
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "viewType": "XML",
        "path": "q-a-test-project.view",
        "controlId": "layout",
        "controlAggregation": "beginColumnPages",
        "transition": "slide"
      },
      "routes": [
        {
          "pattern": "",
          "name": "main",
          "target": ["entityMenu"]
        },
        {
          "pattern": "uSERS",
          "name": "uSERSList",
          "target": ["entityMenu", "uSERSList"]
        },
        {
          "pattern": "uSERS/{ uSERSKey}",
          "name": "uSERSDetail",
          "target": ["entityMenu", "uSERSList", "uSERSDetail"]
        },
        {
          "pattern": "pOSTS",
          "name": "pOSTSList",
          "target": ["entityMenu", "pOSTSList"]
        },
        {
          "pattern": "pOSTS/{ pOSTSKey}",
          "name": "pOSTSDetail",
          "target": ["entityMenu", "pOSTSList", "pOSTSDetail"]
        },
        {
          "pattern": "cOMMENTS",
          "name": "cOMMENTSList",
          "target": ["entityMenu", "cOMMENTSList"]
        },
        {
          "pattern": "cOMMENTS/{ cOMMENTSKey}",
          "name": "cOMMENTSDetail",
          "target": ["entityMenu", "cOMMENTSList", "cOMMENTSDetail"]
        },
        {
          "pattern": "tAGS",
          "name": "tAGSList",
          "target": ["entityMenu", "tAGSList"]
        },
        {
          "pattern": "tAGS/{ tAGSKey}",
          "name": "tAGSDetail",
          "target": ["entityMenu", "tAGSList", "tAGSDetail"]
        },
        {
          "pattern": "pOSTTAGS",
          "name": "pOSTTAGSList",
          "target": ["entityMenu", "pOSTTAGSList"]
        },
        {
          "pattern": "pOSTTAGS/{ pOSTTAGSKey}",
          "name": "pOSTTAGSDetail",
          "target": ["entityMenu", "pOSTTAGSList", "pOSTTAGSDetail"]
        },
        {
          "pattern": "entity/bus_users",
          "name": "uSERSListRoute",
          "target": ["master", "entity.USERSList"]
        },
        {
          "pattern": "entity/bus_users/{id}",
          "name": "uSERSDetailRoute",
          "target": ["master", "entity.USERSList", "entity.USERSDetail"]
        },
        {
          "pattern": "entity/bus_users/create",
          "name": "uSERSCreateRoute",
          "target": ["master", "entity.USERSCreate"]
        },
        {
          "pattern": "entity/bus_posts",
          "name": "pOSTSListRoute",
          "target": ["master", "entity.POSTSList"]
        },
        {
          "pattern": "entity/bus_posts/{id}",
          "name": "pOSTSDetailRoute",
          "target": ["master", "entity.POSTSList", "entity.POSTSDetail"]
        },
        {
          "pattern": "entity/bus_posts/create",
          "name": "pOSTSCreateRoute",
          "target": ["master", "entity.POSTSCreate"]
        },
        {
          "pattern": "entity/bus_comments",
          "name": "cOMMENTSListRoute",
          "target": ["master", "entity.COMMENTSList"]
        },
        {
          "pattern": "entity/bus_comments/{id}",
          "name": "cOMMENTSDetailRoute",
          "target": ["master", "entity.COMMENTSList", "entity.COMMENTSDetail"]
        },
        {
          "pattern": "entity/bus_comments/create",
          "name": "cOMMENTSCreateRoute",
          "target": ["master", "entity.COMMENTSCreate"]
        },
        {
          "pattern": "entity/bus_tags",
          "name": "tAGSListRoute",
          "target": ["master", "entity.TAGSList"]
        },
        {
          "pattern": "entity/bus_tags/{id}",
          "name": "tAGSDetailRoute",
          "target": ["master", "entity.TAGSList", "entity.TAGSDetail"]
        },
        {
          "pattern": "entity/bus_tags/create",
          "name": "tAGSCreateRoute",
          "target": ["master", "entity.TAGSCreate"]
        },
        {
          "pattern": "entity/bus_post_tags",
          "name": "pOSTTAGSListRoute",
          "target": ["master", "entity.POSTTAGSList"]
        },
        {
          "pattern": "entity/bus_post_tags/{id}",
          "name": "pOSTTAGSDetailRoute",
          "target": ["master", "entity.POSTTAGSList", "entity.POSTTAGSDetail"]
        },
        {
          "pattern": "entity/bus_post_tags/create",
          "name": "pOSTTAGSCreateRoute",
          "target": ["master", "entity.POSTTAGSCreate"]
        }
      ],
      "targets": {
        "entityMenu": {
          "name": "EntityMenu",
          "controlAggregation": "beginColumnPages",
          "level": 1
        },
        "uSERSList": {
          "name": "USERSList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "uSERSDetail": {
          "name": "USERSDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "pOSTSList": {
          "name": "POSTSList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "pOSTSDetail": {
          "name": "POSTSDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "cOMMENTSList": {
          "name": "COMMENTSList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "cOMMENTSDetail": {
          "name": "COMMENTSDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "tAGSList": {
          "name": "TAGSList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "tAGSDetail": {
          "name": "TAGSDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "pOSTTAGSList": {
          "name": "POSTTAGSList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "pOSTTAGSDetail": {
          "name": "POSTTAGSDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "entity.USERSList": {
          "viewId": "entity.USERSList",
          "viewName": "entity.USERSList",
          "controlAggregation": "midColumnPages"
        },
        "entity.USERSDetail": {
          "viewId": "entity.USERSDetail",
          "viewName": "entity.USERSDetail",
          "controlAggregation": "endColumnPages"
        },
        "entity.USERSCreate": {
          "viewId": "entity.USERSCreate",
          "viewName": "entity.USERSCreate",
          "controlAggregation": "endColumnPages"
        },
        "entity.POSTSList": {
          "viewId": "entity.POSTSList",
          "viewName": "entity.POSTSList",
          "controlAggregation": "midColumnPages"
        },
        "entity.POSTSDetail": {
          "viewId": "entity.POSTSDetail",
          "viewName": "entity.POSTSDetail",
          "controlAggregation": "endColumnPages"
        },
        "entity.POSTSCreate": {
          "viewId": "entity.POSTSCreate",
          "viewName": "entity.POSTSCreate",
          "controlAggregation": "endColumnPages"
        },
        "entity.COMMENTSList": {
          "viewId": "entity.COMMENTSList",
          "viewName": "entity.COMMENTSList",
          "controlAggregation": "midColumnPages"
        },
        "entity.COMMENTSDetail": {
          "viewId": "entity.COMMENTSDetail",
          "viewName": "entity.COMMENTSDetail",
          "controlAggregation": "endColumnPages"
        },
        "entity.COMMENTSCreate": {
          "viewId": "entity.COMMENTSCreate",
          "viewName": "entity.COMMENTSCreate",
          "controlAggregation": "endColumnPages"
        },
        "entity.TAGSList": {
          "viewId": "entity.TAGSList",
          "viewName": "entity.TAGSList",
          "controlAggregation": "midColumnPages"
        },
        "entity.TAGSDetail": {
          "viewId": "entity.TAGSDetail",
          "viewName": "entity.TAGSDetail",
          "controlAggregation": "endColumnPages"
        },
        "entity.TAGSCreate": {
          "viewId": "entity.TAGSCreate",
          "viewName": "entity.TAGSCreate",
          "controlAggregation": "endColumnPages"
        },
        "entity.POSTTAGSList": {
          "viewId": "entity.POSTTAGSList",
          "viewName": "entity.POSTTAGSList",
          "controlAggregation": "midColumnPages"
        },
        "entity.POSTTAGSDetail": {
          "viewId": "entity.POSTTAGSDetail",
          "viewName": "entity.POSTTAGSDetail",
          "controlAggregation": "endColumnPages"
        },
        "entity.POSTTAGSCreate": {
          "viewId": "entity.POSTTAGSCreate",
          "viewName": "entity.POSTTAGSCreate",
          "controlAggregation": "endColumnPages"
        }
      }
    },
    "rootView": {
      "viewName": "q-a-test-project.view.App",
      "type": "XML",
      "id": "layout"
    }
  }
}
