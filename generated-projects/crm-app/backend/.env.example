# crm-app - Backend Configuration
# Generated: 2026-05-12T11:57:03.530Z

# Server
PORT=3000
NODE_ENV=development

# Main Application Database
DATABASE_CLIENT=better-sqlite3
DATABASE_FILENAME=./data/crm-app.db

# BetterAuth Authentication Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
# BetterAuth will use crm-app_auth database

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Rate Limiting
# Default: 10 requests per minute
# Can be overridden per controller with @Throttle() decorator

# Session Configuration
# BetterAuth session expires in 1 day (86400 seconds)
