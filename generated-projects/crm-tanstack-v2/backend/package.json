{
  "name": "crm-app-backend",
  "version": "1.0.0",
  "description": "Generated CRM Application with Accounts, Contacts, Opportunities and Activities - NestJS Backend",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/main.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun run dist/main",
    "lint": "biome lint --write src",
    "lint:fix": "biome lint --write src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "migrate": "bun run src/migrate.ts latest",
    "migrate:down": "bun run src/migrate.ts down",
    "db:setup": "bun run src/migrate.ts latest"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.11",
    "@better-auth/utils": "^0.4.0",
    "@electric-sql/pglite": "^0.2.17",
    "@fastify/static": "^6.12.0",
    "@gorules/zen-engine": "^0.54.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@trigger.dev/sdk": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.6.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.0",
    "fastify": "^4.25.0",
    "kysely": "^0.28.14",
    "kysely-pglite-dialect": "^1.3.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  }
}
