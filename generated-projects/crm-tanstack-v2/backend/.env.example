# CRM App - Backend Configuration
# Generated: 2026-05-15T16:06:25.868Z

# Server
PORT=3000
NODE_ENV=development

# Database (PGLite - file-based embedded PostgreSQL)
DATABASE_DIR=./data/c_r_m _app.db

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Rate Limiting
# Default: 10 requests per minute
# Can be overridden per controller with @Throttle() decorator

# Session Configuration
# BetterAuth session expires in 1 day (86400 seconds)
