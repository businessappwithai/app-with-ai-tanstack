%% ============================================================================
%% EML Example — Helpdesk / Support Ticketing
%% A simple, complete model: the data model (ERD), a declarative business rule
%% (ticket prioritization), and a workflow (ticket lifecycle state machine)
%% plus lifecycle hooks. Every diagram is valid, renderable Mermaid.
%% ============================================================================

%% ---- Section 1: ERD --------------------------------------------------------
%%meta name: Helpdesk
%%meta kind: erd
%%meta version: 1.0.0
%%enum TicketStatus: open, in_progress, resolved, closed
%%enum TicketPriority: low, medium, high, urgent
%%enum CustomerTier: free, pro, enterprise
erDiagram
    Customer {
        string id PK
        string email UK
        string name
        string tier
        boolean is_active
    }

    Agent {
        string  id PK
        string  email UK
        string  name
        boolean is_active
    }

    Ticket {
        string  id PK
        string  customer_id FK
        string  agent_id FK OPTIONAL
        string  subject
        text    description OPTIONAL
        integer impact_score
        string  priority OPTIONAL
        string  status OPTIONAL
    }

    Comment {
        string  id PK
        string  ticket_id FK
        string  author
        text    body
        boolean is_internal
    }

    Customer ||--o{ Ticket  : "opens"
    Agent    ||--o{ Ticket  : "assigned"
    Ticket   ||--o{ Comment : "has"

    %%field Customer.tier enum: CustomerTier
    %%field Ticket.status enum: TicketStatus
    %%field Ticket.priority enum: TicketPriority
    %%index Ticket(customer_id, status)
    %%index Customer(email) unique
    %%entity Ticket audited: true

%% ---- Section 2: Business rule — ticket prioritization ----------------------
%% Decision reads the ticket's own impact_score, so it evaluates on real data.
%%meta name: Ticket Prioritization
%%meta kind: rules
%%rule prioritize on Ticket event: beforeCreate priority: 10
flowchart TD
    A([Start: Ticket Created]) --> B{impact_score >= 80?}
    B -->|Yes| P1[Set Priority urgent]
    B -->|No| C{impact_score >= 50?}
    C -->|Yes| P2[Set Priority high]
    C -->|No| P3[Set Priority low]
    P1 --> E([End: Prioritized])
    P2 --> E
    P3 --> E

%% ---- Section 3: Workflow — ticket lifecycle (state machine) ----------------
%%meta name: Ticket Lifecycle
%%meta kind: workflow
%%workflow TicketLifecycle entity: Ticket kind: state
stateDiagram-v2
    [*] --> open
    open        --> in_progress : assign
    open        --> closed      : cancel
    in_progress --> resolved    : resolve
    resolved    --> in_progress : reopen
    resolved    --> closed      : close
    closed      --> [*]

    %%guard role:agent|admin on Ticket.update
    %%trigger cron:0 * * * * -> escalateStale on Ticket

%% ---- Section 4: Workflow — ticket hooks ------------------------------------
%%meta name: Ticket Hooks
%%meta kind: workflow
%%workflow TicketHooks entity: Ticket kind: hook
flowchart TD
    A[Client Request] --> B[Validate Request]
    B --> C[beforeCreate: stampReference]
    C --> D[Process Ticket]
    D --> E[afterCreate: notifyCustomer]
    E --> F[afterUpdate: logStatusChange]
    F --> G[Response]

    %%hook beforeCreate stampReference on Ticket
    %%hook afterCreate notifyCustomer on Ticket
    %%hook afterUpdate logStatusChange on Ticket
